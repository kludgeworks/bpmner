{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "rules/**/*.ts",
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
