// Build-time-only docs generator. Imports rules via `import*` glob (the same pattern
// the now-removed Catalog.pkl used) so this file remains independent of the
// build-generated `RulesIndex.pkl`, which `pkl_eval` cannot consume as a dep input.
// The runtime loader continues to use `RulesIndex.pkl` for explicit module imports;
// docs generation just doesn't need to.
local ruleModules = import*("rules/*.pkl")
local rules = ruleModules.toMap().values.toList().sortBy((r) -> r.id)

/// Generator for BPMN Cookbook Rule Documentation in Markdown format.
local function staticConfigMap(rule) =
  if (rule.staticConfig == null) Map() else rule.staticConfig.toMap()

local function cookbookCodeLine(rule) =
  let (config = staticConfigMap(rule))
    if (config.containsKey("cookbookCode"))
      "- **Cookbook Code**: `\(config["cookbookCode"])`\n"
    else
      ""

local function aliasesLine(rule) =
  if (!rule.aliases.isEmpty) "- **Legacy Aliases**: `\(rule.aliases.join("`, `"))`\n" else ""

local function deprecationLines(rule) =
  if (rule.deprecated)
    "- **Deprecated**: Yes\n- **Replaced By**: `\(rule.replacedBy.join("`, `"))`\n- **Deprecation Reason**: \(rule.deprecationReason)\n"
  else
    ""

output {
  files {
    for (rule in rules) {
      ["\(rule.id).md"] {
        text =
          """
          # \(rule.id)

          - **Name**: \(rule.name)
          - **Category**: \(rule.category.name)
          - **Severity**: \(rule.severity)
          - **Target Elements**: `\(rule.targetElements.join("`, `"))`
          \(cookbookCodeLine(rule))\(aliasesLine(rule))\(deprecationLines(rule))

          ## Intent
          \(rule.intent)

          ## Modeller Guidance
          \(rule.forModellers)

          ## AI Guidance
          \(rule.forAI)

          ## Diagnostic Messages
          \(rule.errorMessages.toMap().entries.map((e) -> "- `\(e.first)`: \(e.second)").join("\n"))

          ## Repair
          - **Kind**: `\(rule.repair.kind)`
          - **Safety**: `\(rule.repair.safety)`
          \(if (rule.repair.handler != null) "- **Handler**: `\(rule.repair.handler)`\n          " else "")
          \(if (rule.repair.replacementMap != null)
            """

            ### Replacements
            \(rule.repair.replacementMap.toMap().entries.map((e) -> "- `\(e.first)` → `\(e.second)`").join("\n"))
            """
          else
            "")
          """.trim() + "\n"
      }
    }

    ["README.md"] {
      text =
        """
        # Plugin Rule Documentation

        This folder documents each custom rule implemented by `bpmnlint-plugin-bpmner`.

        ## Rules
        \(rules.sortBy((r) -> r.id).map((r) -> "- [\(r.id)](\(r.id).md): \(r.name)").join("\n"))
        """.trim() + "\n"
    }
  }
}
