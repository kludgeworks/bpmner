amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Event Based Direct Events"
category = RuleCategory.Gateway

intent = "Enforce event-based gateway semantics."
forModellers =
  "Use event-based gateways only when the process waits for events, and connect outgoing flows directly to intermediate catch events or receive tasks."
forAI =
  "Detect event-based gateway outgoing flows that target anything other than an intermediate catch event or receive task."

targetElements = List("bpmn:EventBasedGateway")

severity = "error"
errorMessages = new {
  ["default"] =
    "Event-based gateway must connect directly to intermediate catch events or receive tasks"
}

staticConfig = new {
  allowedTargets = List("bpmn:IntermediateCatchEvent", "bpmn:ReceiveTask")
}

hasTsImplementation = true

// EVENT_BASED_GATEWAY_DIRECT_EVENTS hardcodes the allowed targets (intermediate catch
// events and receive tasks per BPMN 2.0 §10.5.4.6). The `allowedTargets` in staticConfig
// is the legacy JS-bridge mirror — kept until 2G retires that path.
checkPrimitive = "ElementConstraintCheck"
checkConfig = new CheckPrimitive.ElementConstraintCheck {
  element = "bpmn:EventBasedGateway"
  mode = "EVENT_BASED_GATEWAY_DIRECT_EVENTS"
}
