amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Loop Task Annotation"
category = RuleCategory.Activity

intent = "Ensure loop activities document the condition that stops repetition."
forModellers =
  "Attach a text annotation to each loop task or subprocess that explains the loop condition, for example Loop until the condition is met."
forAI =
  "Detect standard loop activities without an associated annotation whose text contains loop intent and a condition such as until, while, unless, or till."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
  )

severity = "error"
errorMessages = new {
  ["default"] = "Loop activity is missing a linked text annotation expressing loop-until intent"
}

staticConfig = new {
  loopWords =
    List(
      "loop",
      "loops",
      "looping",
      "repeat",
      "repeats",
      "repeating",
      "retry",
      "retries",
      "retrying",
      "rework",
      "reworks",
      "reworking",
    )
  conditionWords = List("until", "while", "unless", "till")
}

// No checkPrimitive / checkConfig: this rule is inactive and skipped at load time. The domain
// model represents only multi-instance loop characteristics, not `bpmn:StandardLoopCharacteristics`,
// so there is no element for a standard-loop check to target.
