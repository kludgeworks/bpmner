amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Loop Task Annotation"
category = RuleCategory.Activity

intent = "Ensure loop activities document the condition that stops repetition."
forModellers =
  "Attach a text annotation to each loop task or subprocess that explains the loop condition, for example Loop until the condition is met."
forAI =
  "Detect standard loop activities without an associated annotation whose text contains loop intent and a condition such as until, while, unless, or till."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
  )

severity = "error"
errorMessages = new {
  ["default"] = "Loop activity is missing a linked text annotation expressing loop-until intent"
}

staticConfig = new {
  loopWords =
    List(
      "loop",
      "loops",
      "looping",
      "repeat",
      "repeats",
      "repeating",
      "retry",
      "retries",
      "retrying",
      "rework",
      "reworks",
      "reworking",
    )
  conditionWords = List("until", "while", "unless", "till")
}

// Intentionally left DORMANT (no checkPrimitive / checkConfig): the domain model does not yet
// represent `bpmn:StandardLoopCharacteristics`, only multi-instance (see #188). When standard
// loop support lands, wire this as a CompositeCheck mirroring MiTaskAnnotation — sub-checks
// narrowed via `appliesWhenProperty = "standardLoopCharacteristics"`, with the VocabularyCheck
// requiring a loopWord plus a conditionWord in the linked annotation text.
