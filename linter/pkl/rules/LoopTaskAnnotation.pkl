amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Loop Task Annotation"
category = RuleCategory.Activity

intent = "Ensure loop activities document the condition that stops repetition."
forModellers =
  "Attach a text annotation to each loop task or subprocess that explains the loop condition, for example Loop until the condition is met."
forAI =
  "Detect standard loop activities without an associated annotation whose text contains loop intent and a condition such as until, while, unless, or till."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
  )

severity = "error"
errorMessages = new {
  ["default"] =
    "Loop activity's annotation must express the loop condition with until, while, unless, or till"
}

staticConfig = new {
  conditionWords = List("until", "while", "unless", "till")
}

// The associated annotation's text must express the loop condition. Narrowed to standard-loop
// tasks via `appliesWhenProperty` (the `standardLoopCharacteristics` / `annotationText` properties
// are projected by `PrimitiveModelMapping`). A loop task with no annotation carries no
// `annotationText`, so the REQUIRE check fires on it too — covering both the missing-annotation and
// the wrong-wording cases in one check.
checkPrimitive = "VocabularyCheck"
checkConfig = new CheckPrimitive.VocabularyCheck {
  property = "annotationText"
  mode = "REQUIRE"
  words = staticConfig.conditionWords
  appliesWhenProperty = "standardLoopCharacteristics"
}
