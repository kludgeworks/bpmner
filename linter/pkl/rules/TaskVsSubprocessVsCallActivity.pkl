amends "../schema/BpmnRule.pkl"
import "../schema/RuleCategory.pkl"

name = "Task Vs Subprocess Vs Call Activity"
category = RuleCategory.Activity

intent = "Distinguish between atomic tasks, embedded subprocesses, and reusable call activities."
forModellers =
  "Use Task for atomic work, Subprocess for embedded compound activities, and Call Activity for reusable processes defined externally."
forAI =
  "Identify embedded logic that should be a Subprocess versus external logic that should be a Call Activity."

targetElements = List("bpmn:Task", "bpmn:SubProcess", "bpmn:CallActivity")

severity = "warning"
errorMessages = new {
  ["default"] =
    "Ensure correct use of Task, Subprocess, or Call Activity based on atomicity and reusability."
}

hasTsImplementation = false
