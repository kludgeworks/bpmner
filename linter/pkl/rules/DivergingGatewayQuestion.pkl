amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Diverging Gateway Question"
category = RuleCategory.Gateway

intent = "Encourage question-style naming on diverging exclusive and inclusive gateways."
forModellers =
  "Name diverging exclusive and inclusive gateways with a question that expresses the decision."
forAI =
  "Detect diverging exclusive and inclusive gateways with missing names or names that are not interrogative."

targetElements =
  List(
    "bpmn:ExclusiveGateway",
    "bpmn:InclusiveGateway",
  )

severity = "warning"
errorMessages = new {
  ["default"] = "Diverging exclusive/inclusive gateway should be named as a question"
}

staticConfig = new {
  interrogativeStarters =
    List(
      "is",
      "are",
      "am",
      "was",
      "were",
      "do",
      "does",
      "did",
      "can",
      "could",
      "will",
      "would",
      "shall",
      "should",
      "may",
      "might",
      "must",
      "have",
      "has",
      "had",
      "who",
      "what",
      "when",
      "where",
      "why",
      "how",
      "which",
      "whose",
      "whom",
    )
}

// Phase 3 (#218): activate via GrammaticalShapeCheck. QUESTION_FORM passes when the leading
// token is a WH-word or modal/copular auxiliary, OR when the label ends with `?`. The
// `interrogativeStarters` list above is presentation/legacy metadata — every entry is
// either a WH-word or an auxiliary, both of which the BpmnNlp facade tags accordingly.
checkPrimitive = "GrammaticalShapeCheck"
checkConfig = new CheckPrimitive.GrammaticalShapeCheck {
  property = "name"
  mode = "QUESTION_FORM"
}
