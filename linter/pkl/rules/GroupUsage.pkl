amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Group Usage"
category = RuleCategory.Artifact

intent = "Keep BPMN groups as visual, non-semantic containers."
forModellers = "Use Group to visually group related elements; it does not affect process logic."
forAI =
  "Treat groups as visual, non-semantic containers. Do not infer control flow, data flow, ownership, or membership semantics from a group."

targetElements = List("bpmn:Group")

severity = "info"
errorMessages = new {
  ["default"] = "Groups are visual containers and require modelling context"
}

checkPrimitive = "PresenceCheck"
checkConfig = new CheckPrimitive.PresenceCheck {}

staticConfig = new {
  cookbookCode = "ART-01"
}
