amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "KLOps Allowed Elements"
category = RuleCategory.General

intent = "Keep models within the KLOps BPMN subset."
forModellers =
  "Use only the BPMN elements described in the KLOps BPMN toolbox and avoid unsupported exotic BPMN constructs."
forAI =
  "Detect discouraged BPMN types that are outside the KLOps subset and propose supported replacements."

targetElements =
  List(
    "bpmn:Choreography",
    "bpmn:ChoreographyTask",
    "bpmn:SubChoreography",
    "bpmn:CallChoreography",
    "bpmn:Conversation",
    "bpmn:ConversationLink",
    "bpmn:ConversationAssociation",
    "bpmn:Transaction",
    "bpmn:CompensateEventDefinition",
    "bpmn:EscalationEventDefinition",
  )

severity = "error"
errorMessages = new {
  ["default"] = "Element type is outside the KLOps BPMN subset"
}

staticConfig = new {
  discouragedTypes =
    List(
      "bpmn:Choreography",
      "bpmn:ChoreographyTask",
      "bpmn:SubChoreography",
      "bpmn:CallChoreography",
      "bpmn:Conversation",
      "bpmn:ConversationLink",
      "bpmn:ConversationAssociation",
      "bpmn:Transaction",
      "bpmn:CompensateEventDefinition",
      "bpmn:EscalationEventDefinition",
    )
}

autoFixable = false
fixStrategy = "LLM"
