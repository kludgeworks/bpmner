amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Actor Artifact Usage"
category = RuleCategory.Lane

intent = "Treat Actor custom artifacts as lane clarification only."
forModellers =
  "Use an Actor custom artifact inside a lane only to clarify who performs the lane activities; it does not replace the lane."
forAI =
  "Do not infer additional participants, lanes, control flow, or responsibility semantics from Actor artifacts."

targetElements = List("bpmn:Artifact")

severity = "info"
errorMessages = new {
  ["default"] = "Actor artifacts are documentation only and require modelling context"
}

staticConfig = new {
  cookbookCode = "LANE-02"
}

// Info-level advisory on any Actor custom artifact, mirroring GroupUsage: presence alone surfaces
// the "documentation only" guidance. The model emits no bpmn:Artifact today, so it never fires in
// practice — it loads through the active path, ready for when actor artifacts are modelled.
checkPrimitive = "PresenceCheck"
checkConfig = new CheckPrimitive.PresenceCheck {}
