amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Required Annotation Association"
category = RuleCategory.Association

intent =
  "Require explicit association links from loop and multi-instance activities to their explanatory annotations."
forModellers =
  "Use an association to link required text annotations to loop or multi-instance tasks and subprocesses."
forAI = "Detect loop or multi-instance activities that do not have any associated text annotation."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
  )

severity = "error"
errorMessages = new {
  ["default"] =
    "Loop or multi-instance activity must be linked to a text annotation via association"
}

staticConfig = new {
  loopCharacteristics =
    List("bpmn:StandardLoopCharacteristics", "bpmn:MultiInstanceLoopCharacteristics")
}

autoFixable = false
fixStrategy = "LLM"
