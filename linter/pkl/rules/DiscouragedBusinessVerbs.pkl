amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Discouraged Business Verbs"
category = RuleCategory.Activity

intent = "Avoid generic activity verbs that hide the real business action."
forModellers = "Replace vague leading verbs with a more specific business verb."
forAI = "Detect activity labels whose first word is on the discouraged generic verb list."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
    "bpmn:CallActivity",
  )

severity = "warning"
errorMessages = new {
  ["default"] =
    "Activity label starts with a discouraged generic verb; prefer a more specific business verb"
}

staticConfig = new {
  discouragedLeadingVerbs = List("handle", "manage", "process", "perform", "do")
}

hasTsImplementation = true

// VocabularyCheck tokenizes the property value and flags any token matching the FORBID list.
// `discouragedLeadingVerbs` in staticConfig is the legacy JS-bridge mirror of `words` here —
// they stay in sync by convention; the JS path dies in 2G and the staticConfig copy with it.
checkPrimitive = "VocabularyCheck"
checkConfig = new CheckPrimitive.VocabularyCheck {
  property = "name"
  mode = "FORBID"
  words = List("handle", "manage", "process", "perform", "do")
}
