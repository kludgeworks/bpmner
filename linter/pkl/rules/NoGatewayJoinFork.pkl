amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "No Gateway Join Fork"
category = RuleCategory.Gateway

intent = "Prevent a single gateway from acting as both a join and a fork."
forModellers =
  "Use separate converging and diverging gateways instead of one gateway with multiple incoming and multiple outgoing flows."
forAI =
  "Detect exclusive, inclusive, or parallel gateways with at least two incoming and at least two outgoing flows."

targetElements =
  List(
    "bpmn:ExclusiveGateway",
    "bpmn:InclusiveGateway",
    "bpmn:ParallelGateway",
  )

severity = "error"
errorMessages = new {
  ["default"] =
    "Gateway acts as both join and fork; split into separate converging and diverging gateways"
}

staticConfig = new {}

checkPrimitive = "TopologyCheck"
checkConfig = new CheckPrimitive.TopologyCheck {
  topology = "NO_JOIN_FORK"
}

repair = new {
  kind = "LOCAL_MODEL_FIX"
  safety = "SAFE_AUTOMATIC"
  handler = "splitJoinForkGateway"
}
