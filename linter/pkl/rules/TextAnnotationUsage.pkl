amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Text Annotation Usage"
category = RuleCategory.Artifact

intent = "Ensure text annotations are explicitly connected to the element they clarify."
forModellers =
  "Use Text Annotation to document clarifications or extra details, and attach it to its target with an association."
forAI =
  "Require text annotations to have at least one association; loop and multi-instance specificity remains covered by activity and association rules."

targetElements = List("bpmn:TextAnnotation")

severity = "warning"
errorMessages = new {
  ["default"] = "Text annotation must be linked to a BPMN element with an association"
}

staticConfig = new {
  cookbookCode = "ART-02"
}

// Every text annotation must be referenced by at least one association. BPMN models the link
// with sourceRef = annotated element and targetRef = annotation, so the annotation is the
// association's TARGET — hence INBOUND. No `appliesWhenProperty`: the rule applies to all
// text annotations. `targetTypes` is empty so the other end may be any element.
checkPrimitive = "RequiredAssociationCheck"
checkConfig = new CheckPrimitive.RequiredAssociationCheck {
  association = "bpmn:Association"
  direction = "INBOUND"
}
