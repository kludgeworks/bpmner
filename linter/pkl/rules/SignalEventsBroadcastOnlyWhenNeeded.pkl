amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Signal Events Broadcast Only When Needed"
category = RuleCategory.Event

intent = "Reserve signal events for broadcast semantics."
forModellers =
  "Use signal events when one throw can be observed by multiple independent catchers. Prefer message, error, or escalation events when the receiver or exception scope is specific."
forAI =
  "Treat signal event replacement as a modelling-intent heuristic. Deterministic linting can identify signal event usage, but deciding whether a message, error, or escalation is better requires business context."

targetElements =
  List(
    "bpmn:StartEvent",
    "bpmn:IntermediateCatchEvent",
    "bpmn:IntermediateThrowEvent",
    "bpmn:BoundaryEvent",
    "bpmn:EndEvent",
  )

severity = "warning"
errorMessages = new {
  ["default"] = "Signal events should be used only when broadcast behavior is required"
}

staticConfig = new {
  eventDefinition = "bpmn:SignalEventDefinition"
  preferredAlternatives =
    List(
      "bpmn:MessageEventDefinition",
      "bpmn:ErrorEventDefinition",
      "bpmn:EscalationEventDefinition",
    )
}

checkPrimitive = null
checkConfig = null
