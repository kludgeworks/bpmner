amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Business Meaningful Label"
category = RuleCategory.Name

intent = "Encourage business-readable labels over technical identifiers."
forModellers =
  "Choose names that are meaningful to business stakeholders and avoid technical shorthand, code names, and implementation identifiers."
forAI =
  "Detect labels containing technical patterns such as underscores, slash paths, alphanumeric codes, or configured technical tokens."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
    "bpmn:CallActivity",
    "bpmn:StartEvent",
    "bpmn:IntermediateCatchEvent",
    "bpmn:IntermediateThrowEvent",
    "bpmn:EndEvent",
    "bpmn:ExclusiveGateway",
    "bpmn:InclusiveGateway",
    "bpmn:ParallelGateway",
    "bpmn:ComplexGateway",
    "bpmn:DataObjectReference",
    "bpmn:DataStoreReference",
  )

severity = "warning"
errorMessages = new {
  ["default"] = "Label appears technical/cryptic; prefer business-meaningful wording"
}

// Single-source-of-truth list referenced both in `staticConfig` (so tools and docs can
// introspect it) and in `checkConfig.forbiddenVocabulary` (so the runtime check honours it).
// The `local` identifier is deliberately different from the `staticConfig` field name to
// avoid a Pkl self-reference (`x = x`) at the field initialiser.
local technicalTokenList: List<String> =
  List("api", "svc", "tbl", "req", "resp", "tmp", "proc", "obj")

staticConfig = new {
  technicalTokens = technicalTokenList
}

checkPrimitive = "PropertyPatternCheck"
// Reject labels that contain any of: underscore, slash, mid-token camelCase (`a→A`
// transition), or a digit (alphanumeric code like `Form1` / `T123`). Pattern is
// inclusion-based — labels matching ALL three negative lookaheads pass; any one trips the
// flag. `forbiddenVocabulary` then layers a case-insensitive technical-token blocklist on
// top (so `Submit api request` flags even though it passes the regex).
checkConfig = new CheckPrimitive.PropertyPatternCheck {
  property = "name"
  pattern = "^(?!.*[_/])(?!.*[a-z][A-Z])(?!.*\\d).+$"
  patternDescription =
    "labels should be business-readable (no underscores, slash paths, camelCase, or digits)"
  forbiddenVocabulary = technicalTokenList
}
