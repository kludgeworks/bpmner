amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Timer Start Events Block Until Time"
category = RuleCategory.Event

intent = "Ensure timer start events define the time condition that starts the process."
forModellers =
  "Use a timer start event only when the process waits for a specific date, duration, or cycle before starting."
forAI =
  "Detect timer start events with no timer expression or with more than one timer expression. General start-event incoming-flow checks are handled by the start-no-incoming rule."

targetElements = List("bpmn:StartEvent")

severity = "error"
errorMessages = new {
  ["default"] = "Timer start event must define exactly one timer expression"
  ["missingTimerExpression"] = "Timer start event must define a date, duration, or cycle"
  ["multipleTimerExpressions"] = "Timer start event must define only one timer expression"
}

staticConfig = new {
  timerExpressionFields = List("timeDate", "timeDuration", "timeCycle")
}

hasTsImplementation = true

// TIMER_EXPRESSION flags timer events whose `timerExpression` property is blank. The
// primitive supports an optional `constraints.pattern` regex for stricter formats, but
// the legacy rule only enforces presence, so the pattern is omitted. "Multiple timer
// expressions" (the second legacy diagnostic) is an XML-shape concern not visible at
// the parsed-model layer.
checkPrimitive = "ElementConstraintCheck"
checkConfig = new CheckPrimitive.ElementConstraintCheck {
  element = "bpmn:StartEvent"
  mode = "TIMER_EXPRESSION"
}
