amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Sequence Flow Within Pool"
category = RuleCategory.Flow

intent = "Keep sequence flows within a single pool."
forModellers =
  "Use sequence flow only within the same pool; use message flow for communication between pools."
forAI = "Detect sequence flows whose source and target resolve to different pools."

targetElements = List("bpmn:SequenceFlow")

severity = "error"
errorMessages = new {
  ["default"] = "Sequence flow must not cross pool boundaries"
}

staticConfig = new {}

// WITHIN_POOL is dormant in production today — the deterministic primitive short-circuits to
// empty diagnostics until participants, lanes, and per-flow pool fields land via #196. The
// rule still loads through the new path; it just produces no diagnostics until that capability
// bit is enabled.
checkPrimitive = "ConnectivityCheck"
checkConfig = new CheckPrimitive.ConnectivityCheck {
  mode = "WITHIN_POOL"
}
