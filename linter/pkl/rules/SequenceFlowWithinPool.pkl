amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Sequence Flow Within Pool"
category = RuleCategory.Flow

intent = "Keep sequence flows within a single pool."
forModellers =
  "Use sequence flow only within the same pool; use message flow for communication between pools."
forAI = "Detect sequence flows whose source and target resolve to different pools."

targetElements = List("bpmn:SequenceFlow")

severity = "error"
errorMessages = new {
  ["default"] = "Sequence flow must not cross pool boundaries"
}

staticConfig = new {}

hasTsImplementation = true
