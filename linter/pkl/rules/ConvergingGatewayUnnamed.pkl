amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Converging Gateway Unnamed"
category = RuleCategory.Gateway

intent = "Keep converging gateway labels empty so decision wording stays on the diverging side."
forModellers =
  "Do not name converging exclusive, inclusive, or parallel gateways; use a text annotation if convergence needs explanation."
forAI =
  "Detect converging exclusive, inclusive, or parallel gateways with labels and remove the label when auto-fixing."

targetElements =
  List(
    "bpmn:ExclusiveGateway",
    "bpmn:InclusiveGateway",
    "bpmn:ParallelGateway",
  )

severity = "warning"
errorMessages = new {
  ["default"] = "Converging gateway should remain unnamed"
}

staticConfig = new {}

hasTsImplementation = true

checkPrimitive = "TopologyCheck"
checkConfig = new CheckPrimitive.TopologyCheck {
  topology = "CONVERGING_UNNAMED"
}

repair = new {
  kind = "LOCAL_MODEL_FIX"
  safety = "SAFE_AUTOMATIC"
  handler = "clearConvergingGatewayName"
}
