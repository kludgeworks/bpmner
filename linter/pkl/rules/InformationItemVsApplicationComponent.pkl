amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Information Item Vs Application Component"
category = RuleCategory.Data

intent = "Represent application allocation with Information Item in PRADA/FAD contexts."
forModellers =
  "Use Information Item as the temporary custom BPMN artifact for allocating application components to business processes or activities in PRADA/FAD diagrams."
forAI =
  "Prefer Information Item over Application Component in PRADA/FAD contexts, while recognizing that older diagrams may still contain Application Component."

targetElements = List("bpmn:DataObjectReference", "bpmn:DataStoreReference", "bpmn:Artifact")

severity = "info"
errorMessages = new {
  ["default"] = "Information Item versus Application Component usage requires PRADA/FAD context"
}

staticConfig = new {
  cookbookCode = "DATA-02"
}
