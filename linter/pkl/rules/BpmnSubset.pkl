amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "BPMN Subset"
category = RuleCategory.General

intent = "Keep models within the supported BPMN subset."
forModellers =
  "Use only the BPMN elements described in the supported BPMN subset and avoid unsupported exotic BPMN constructs."
forAI =
  "Detect discouraged BPMN types that are outside the supported subset and propose supported replacements."

targetElements =
  List(
    "bpmn:Choreography",
    "bpmn:ChoreographyTask",
    "bpmn:SubChoreography",
    "bpmn:CallChoreography",
    "bpmn:Conversation",
    "bpmn:ConversationLink",
    "bpmn:ConversationAssociation",
    "bpmn:Transaction",
    "bpmn:CompensateEventDefinition",
    "bpmn:EscalationEventDefinition",
  )

severity = "error"
errorMessages = new {
  ["default"] = "Element type is outside the supported BPMN subset"
}

staticConfig = new {
  discouragedTypes =
    List(
      "bpmn:Choreography",
      "bpmn:ChoreographyTask",
      "bpmn:SubChoreography",
      "bpmn:CallChoreography",
      "bpmn:Conversation",
      "bpmn:ConversationLink",
      "bpmn:ConversationAssociation",
      "bpmn:Transaction",
      "bpmn:CompensateEventDefinition",
      "bpmn:EscalationEventDefinition",
    )
}

hasTsImplementation = true

// BpmnSubset stays on the legacy JS path until pkl-config-java can convert Pkl Lists into
// the Mapping<String, Any> value slot — the codegen target field is java.lang.Object and
// no built-in converter handles `pkl.base#List` -> `java.lang.Object`. Revisit once 2G
// retires the JS path or the codegen converter chain is extended.
