amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "BPMN Subset"
category = RuleCategory.General

intent = "Keep models within the supported BPMN subset."
forModellers =
  "Use only the BPMN elements described in the supported BPMN subset and avoid unsupported exotic BPMN constructs."
forAI =
  "Detect discouraged BPMN types that are outside the supported subset and propose supported replacements."

// Single-source-of-truth list referenced both in `staticConfig` (for tools/docs introspection)
// and in `targetElements` (the rule's element scope). The `local` identifier is deliberately
// different from the `staticConfig` field name to avoid a Pkl self-reference (`x = x`) at the
// field initialiser.
local discouragedTypeList: List<String> =
  List(
    "bpmn:Choreography",
    "bpmn:ChoreographyTask",
    "bpmn:SubChoreography",
    "bpmn:CallChoreography",
    "bpmn:Conversation",
    "bpmn:ConversationLink",
    "bpmn:ConversationAssociation",
    "bpmn:Transaction",
    "bpmn:CompensateEventDefinition",
    "bpmn:EscalationEventDefinition",
  )

targetElements = discouragedTypeList

severity = "error"
errorMessages = new {
  ["default"] = "Element type is outside the supported BPMN subset"
}

staticConfig = new {
  discouragedTypes = discouragedTypeList
}

checkPrimitive = "ElementConstraintCheck"
// `targetElements` already scopes the scan to exactly the 10 discouraged types, so every
// targetedElement is by definition outside the supported subset. `constraints["allowed"]`
// is empty — no exceptions; every match fires. The `allowed` knob exists for rules where
// some target types are acceptable, which BpmnSubset has none of.
//
// #282 reframe: the parser previously rejected these types at parse time
// (`BpmnXmlToDefinitionConverter` would `error("Unsupported BPMN flow node type")`). It now
// surfaces them as `BpmnUnrecognizedNode` / `BpmnUnrecognizedEventDefinition`, and the rule
// engine — driven by this Pkl rule — does the policy enforcement.
checkConfig = new CheckPrimitive.ElementConstraintCheck {
  element = "bpmn:FlowElement"
  mode = "ALLOWED_ELEMENT_SUBSET"
  // The `Mapping<String, Any>` value slot codegens as `java.lang.Object` and
  // `pkl-config-java` has no built-in `pkl.base#List → java.lang.Object` converter, so we
  // smuggle the allowed list as a comma-separated string. The Kotlin side
  // (`ElementConstraintCheck.allowedSubset`) accepts both `List<String>` and `String`
  // (CSV-split). Empty string == "no allowed types" == every targetedElement fires.
  constraints = new Mapping<String, Any> {
    ["allowed"] = ""
  }
}
