amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Message Flow Name Pattern"
category = RuleCategory.Message

intent = "Encourage noun-based message naming over action phrasing."
forModellers =
  "Label message flows with the message name, such as Approval confirmation, rather than an action such as Send approval."
forAI = "Detect message flow labels that start with a verb or auxiliary token."

targetElements = List("bpmn:MessageFlow")

severity = "warning"
errorMessages = new {
  ["default"] = "Message flow name should describe the message, not an action"
}

staticConfig = new {}

// Fires when a message flow's label leads with a verb (action phrasing like "Send approval")
// rather than a noun message name. Mirrors IntermediateEventNotAction's leading-verb guard.
checkPrimitive = "PartOfSpeechCheck"
checkConfig = new CheckPrimitive.PartOfSpeechCheck {
  property = "name"
  mode = "LEADING_MUST_NOT_BE"
  posClass = "VERB"
}
