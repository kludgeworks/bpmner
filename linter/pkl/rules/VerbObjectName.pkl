amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Verb Object Name"
category = RuleCategory.Activity

intent = "Make activity labels action-oriented and specific."
forModellers = "Name activities with a business verb followed by the object being acted on."
forAI = "Detect activity labels that do not start with a verb or that contain fewer than two words."

targetElements =
  List(
    "bpmn:Task",
    "bpmn:SubProcess",
    "bpmn:CallActivity",
  )

severity = "warning"
errorMessages = new {
  ["tooShort"] = "Activity name should follow Verb + Object (at least two words)"
  ["missingVerb"] = "Activity name should start with a business verb"
  ["default"] = "Activity name should follow Verb + Object"
}

staticConfig = new {}

hasTsImplementation = true

// Partial port: enforces the "at least two words" half of the legacy contract (the
// `tooShort` diagnostic). The `missingVerb` half requires POS tagging which the
// deterministic primitives cannot express — that check stays on the legacy JS path
// until either a part-of-speech-aware primitive lands or 2G retires the JS path.
checkPrimitive = "PropertyPatternCheck"
checkConfig = new CheckPrimitive.PropertyPatternCheck {
  property = "name"
  pattern = "^\\S+\\s+\\S+.*"
  patternDescription = "label should be at least two words (Verb + Object)"
}
