amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "No Type Words In Data Name"
category = RuleCategory.Data

intent = "Keep data element names business-oriented and noun-based."
forModellers =
  "Name data objects and data stores with business noun phrases, without redundant BPMN type words such as activity, process, or event."
forAI = "Detect data object and data store names that include discouraged BPMN type words."

targetElements =
  List(
    "bpmn:DataObjectReference",
    "bpmn:DataStoreReference",
  )

severity = "error"
errorMessages = new {
  ["default"] = "Data element name must be a business noun phrase, not an element-type label"
}

staticConfig = new {
  discouragedWords = List("activity", "process", "event")
}

repair = new {
  kind = "LOCAL_XML_FIX"
  safety = "SAFE_AUTOMATIC"
  handler = "stripTypeWords"
}
