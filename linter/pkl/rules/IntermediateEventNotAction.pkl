amends "../schema/BpmnRule.pkl"

import "../schema/CheckPrimitive.pkl"
import "../schema/RuleCategory.pkl"

name = "Intermediate Event Not Action"
category = RuleCategory.Event

intent = "Ensure intermediate events describe states or happenings rather than work."
forModellers = "Use intermediate events for things that happen while activities perform the work."
forAI =
  "Detect intermediate catch or throw event labels that start with a verb or auxiliary and suggest state-style wording or a task."

targetElements =
  List(
    "bpmn:IntermediateCatchEvent",
    "bpmn:IntermediateThrowEvent",
  )

severity = "warning"
errorMessages = new {
  ["default"] = "Intermediate event name should describe a state, not an action"
}

staticConfig = new {}

// Phase 3 (#218): same primitive as EventStateName — intermediate events follow the same
// "state, not action" convention. STATE_LABEL passes for noun-led or past-participle labels.
checkPrimitive = "GrammaticalShapeCheck"
checkConfig = new CheckPrimitive.GrammaticalShapeCheck {
  property = "name"
  mode = "STATE_LABEL"
}
