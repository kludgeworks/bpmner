amends "pkl:test"

import "../RulesIndex.pkl" as RulesIndex

// Sanity tests for the build-time-generated RulesIndex. The legacy parity check
// against `Catalog.pkl` was retired in 2G when Catalog.pkl itself was deleted —
// RulesIndex is now the authoritative module list.
facts {
  ["RulesIndex rule ids are unique"] {
    RulesIndex.rules.map((rule) -> rule.id).toSet().length == RulesIndex.rules.length
  }

  ["RulesIndex emits at least one rule"] {
    !RulesIndex.rules.isEmpty
  }

  ["RulesIndex rules are sorted by id"] {
    RulesIndex.rules.map((rule) -> rule.id)
      == RulesIndex.rules.map((rule) -> rule.id).toList().sort()
  }
}
