amends "../schema/BpmnRule.pkl"

import "../schema/RuleCategory.pkl"

name = "Invalid Local Route Without Handler"
category = RuleCategory.Activity

intent = "This fixture must fail: LOCAL_MODEL_FIX kind requires a non-empty handler."
forModellers = "This fixture must fail: LOCAL_MODEL_FIX kind requires a non-empty handler."
forAI = "This fixture must fail: LOCAL_MODEL_FIX kind requires a non-empty handler."

targetElements = List("bpmn:Task")
severity = "warning"
errorMessages = new {
  ["default"] = "This fixture should fail"
}

repair = new {
  kind = "LOCAL_MODEL_FIX"
  safety = "SAFE_AUTOMATIC"
}
