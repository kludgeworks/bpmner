amends "pkl:test"

import "../Catalog.pkl" as Catalog

facts {
  ["catalog exposes deterministic migrated IDs"] {
    Catalog.rules.map((rule) -> rule.id)
      == List(
        "act-activity-label-capitalization",
        "act-business-process-element-usage",
        "act-discouraged-business-verbs",
        "act-loop-task-annotation",
        "act-mi-task-annotation",
        "act-receive-task-vs-intermediate-message-event",
        "act-send-task-vs-throwing-message-event",
        "act-task-vs-subprocess-vs-call-activity",
        "act-verb-object-name",
        "art-group-usage",
        "art-text-annotation-usage",
        "assoc-required-annotation-association",
        "data-information-item-vs-application-component",
        "data-no-type-words-in-data-name",
        "evt-boundary-event-constraints",
        "evt-error-end-boundary-pair",
        "evt-event-state-name",
        "evt-event-state-pattern",
        "evt-intermediate-event-not-action",
        "evt-link-event-pairing",
        "evt-message-start-has-message-flow",
        "evt-signal-events-broadcast-only-when-needed",
        "evt-start-no-incoming",
        "evt-timer-start-events-block-until-time",
        "flow-diverging-flow-outcome-label",
        "flow-sequence-flow-within-pool",
        "gen-business-clarity-over-technical-detail",
        "gen-bpmnsubset-allowed-elements",
        "gen-no-duplicate-diagrams",
        "gtw-converging-gateway-unnamed",
        "gtw-diverging-flow-names",
        "gtw-diverging-gateway-question",
        "gtw-event-based-direct-events",
        "gtw-exclusive-inclusive-parallel-semantics",
        "gtw-fake-join",
        "gtw-gateway-no-work-label",
        "gtw-no-gateway-join-fork",
        "gtw-superfluous-gateway",
        "lane-actor-artifact-usage",
        "lane-lane-labels-business-roles-performers",
        "msg-envelope-icon-usage",
        "msg-message-flow-across-pools",
        "msg-message-flow-name-pattern",
        "name-business-meaningful-label",
        "name-no-element-type-words",
        "name-uncommon-abbreviations",
        "pool-black-box-pool-named-by-external-entity-or-process",
        "pool-child-diagrams-keep-pool-process-name",
        "pool-white-box-pool-named-by-process",
      )
  }

  ["catalog IDs are unique"] {
    Catalog.rules.map((rule) -> rule.id).toSet().length == Catalog.rules.length
  }

  ["migrated rules include required messages and static config"] {
    Catalog.rules.every((rule) -> rule.errorMessages.containsKey("default"))
    Catalog.rules
      .find((rule) -> rule.id == "act-verb-object-name")
      .errorMessages
      .containsKey("missingVerb")
    Catalog.rules
      .find((rule) -> rule.id == "act-verb-object-name")
      .errorMessages
      .containsKey("tooShort")
    Catalog.rules
      .find((rule) -> rule.id == "act-discouraged-business-verbs")
      .staticConfig
      .discouragedLeadingVerbs
      .contains("manage")
    Catalog.rules.find((rule) -> rule.id == "gtw-converging-gateway-unnamed").repair.kind
      == "LOCAL_XML_FIX"
    Catalog.rules.find((rule) -> rule.id == "gtw-converging-gateway-unnamed").repair.handler
      == "clearName"
    Catalog.rules
      .find((rule) -> rule.id == "name-uncommon-abbreviations")
      .staticConfig
      .commonAcronyms
      .contains("BPMN")
    Catalog.rules
      .find((rule) -> rule.id == "evt-signal-events-broadcast-only-when-needed")
      .hasTsImplementation
      == false
    Catalog.rules
      .find((rule) -> rule.id == "evt-timer-start-events-block-until-time")
      .staticConfig
      .timerExpressionFields
      .contains("timeCycle")
    Catalog.rules
      .find((rule) -> rule.id == "gtw-exclusive-inclusive-parallel-semantics")
      .errorMessages
      .containsKey("parallelCondition")
    Catalog.rules
      .find((rule) -> rule.id == "pool-white-box-pool-named-by-process")
      .targetElements
      .contains("bpmn:Participant")
    Catalog.rules.find((rule) -> rule.id == "pool-white-box-pool-named-by-process").errorMessages["default"]
      == "White-box pool name should match the referenced process name"
    Catalog.rules.find((rule) -> rule.id == "pool-white-box-pool-named-by-process").repair.kind
      == "LLM_MODEL_PATCH"
    Catalog.rules
      .find((rule) -> rule.id == "pool-black-box-pool-named-by-external-entity-or-process")
      .targetElements
      .contains("bpmn:Participant")
    Catalog.rules
      .find((rule) -> rule.id == "lane-lane-labels-business-roles-performers")
      .targetElements
      .contains("bpmn:Lane")
    Catalog.rules
      .find((rule) -> rule.id == "art-text-annotation-usage")
      .targetElements
      .contains("bpmn:TextAnnotation")
    Catalog.rules.find((rule) -> rule.id == "msg-envelope-icon-usage").staticConfig.diField
      == "bpmndi:BPMNEdge.messageVisibleKind"
    Catalog.rules
      .find((rule) -> rule.id == "gen-business-clarity-over-technical-detail")
      .staticConfig
      .cookbookCode
      == "GEN-02"
    Catalog.rules.find((rule) -> rule.id == "gen-business-clarity-over-technical-detail").severity
      == "info"
    Catalog.rules
      .find((rule) -> rule.id == "gen-no-duplicate-diagrams")
      .aliases
      .contains("gen-02-no-duplicate-diagrams")
  }

  local metadataOnlyRuleIds =
    Set(
      "gen-business-clarity-over-technical-detail",
      "pool-child-diagrams-keep-pool-process-name",
      "lane-actor-artifact-usage",
      "art-group-usage",
      "data-information-item-vs-application-component",
      "msg-envelope-icon-usage",
    )

  ["context-dependent cookbook rules are metadata-only"] {
    Catalog.rules
      .filter((rule) -> metadataOnlyRuleIds.contains(rule.id))
      .every((rule) -> rule.hasTsImplementation == false)
  }

  local fixableRuleIds =
    Set(
      "act-activity-label-capitalization",
      "data-no-type-words-in-data-name",
      "evt-start-no-incoming",
      "gtw-converging-gateway-unnamed",
      "gtw-gateway-no-work-label",
      "gtw-no-gateway-join-fork",
      "gtw-fake-join",
      "gtw-superfluous-gateway",
      "name-uncommon-abbreviations",
      "name-no-element-type-words",
    )

  ["migrated rules have valid repair kinds"] {
    Catalog.rules.every((rule) ->
      List("error", "warning", "info", "off").contains(rule.severity)
        && List(
          "LOCAL_MODEL_FIX",
          "LOCAL_XML_FIX",
          "LLM_MODEL_PATCH",
          "LLM_XML_REWRITE",
          "UNFIXABLE",
        ).contains(rule.repair.kind)
    )
  }

  ["local rules carry handlers and SAFE_AUTOMATIC safety"] {
    Catalog.rules
      .filter((rule) -> fixableRuleIds.contains(rule.id))
      .every((rule) ->
        (rule.repair.kind == "LOCAL_XML_FIX" || rule.repair.kind == "LOCAL_MODEL_FIX")
          && rule.repair.handler != null
          && rule.repair.safety == "SAFE_AUTOMATIC"
      )
  }

  ["name-02 replacement map is present and non-empty"] {
    Catalog.rules.find((rule) -> rule.id == "name-uncommon-abbreviations").repair.replacementMap
      != null
    Catalog.rules
      .find((rule) -> rule.id == "name-uncommon-abbreviations")
      .repair
      .replacementMap
      .containsKey("REQ")
  }
}
