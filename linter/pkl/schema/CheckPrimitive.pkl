typealias NonEmptyString = String(!isEmpty)

typealias CheckPrimitive =
  "RequiredPropertyCheck"
    | "PropertyPatternCheck"
    | "VocabularyCheck"
    | "RequiredAssociationCheck"
    | "TopologyCheck"
    | "ConnectivityCheck"
    | "PairingCheck"
    | "CardinalityCheck"
    | "PoolLabelCheck"
    | "ElementConstraintCheck"
    | "CompositeCheck"
    | "LlmCheckRule"

abstract class CheckConfig

class RequiredPropertyCheck extends CheckConfig {
  property: NonEmptyString
}

class PropertyPatternCheck extends CheckConfig {
  property: NonEmptyString
  pattern: NonEmptyString
  patternDescription: String? = null
}

class VocabularyCheck extends CheckConfig {
  property: NonEmptyString
  mode: "REQUIRE" | "FORBID"
  words: List<NonEmptyString> = List()
}

class RequiredAssociationCheck extends CheckConfig {
  association: NonEmptyString
  sourceTypes: List<NonEmptyString> = List()
  targetTypes: List<NonEmptyString> = List()
}

class TopologyCheck extends CheckConfig {
  topology: "NO_FAKE_JOIN" | "NO_SUPERFLUOUS" | "NO_JOIN_FORK" | "CONVERGING_UNNAMED"
  minIncoming: Int? = null
  maxIncoming: Int? = null
  minOutgoing: Int? = null
  maxOutgoing: Int? = null
}

class ConnectivityCheck extends CheckConfig {
  mode: "NO_INCOMING" | "FLOWS_NAMED" | "WITHIN_POOL" | "ACROSS_POOLS"
  sourceTypes: List<NonEmptyString> = List()
  targetTypes: List<NonEmptyString> = List()
}

class PairingCheck extends CheckConfig {
  mode: "ERROR_END_BOUNDARY" | "LINK_PAIRING" | "MESSAGE_START_FLOW"
  left: String? = null
  right: String? = null
}

class CardinalityCheck extends CheckConfig {
  element: NonEmptyString
  min: Int? = null
  max: Int? = null
}

class PoolLabelCheck extends CheckConfig {
  mode: NonEmptyString
}

class ElementConstraintCheck extends CheckConfig {
  element: NonEmptyString
  mode: "ALLOWED_ELEMENT_SUBSET"
    | "TIMER_EXPRESSION"
    | "PARALLEL_GATEWAY_STRUCTURE"
    | "EVENT_BASED_GATEWAY_DIRECT_EVENTS"
  constraints: Mapping<NonEmptyString, Dynamic> = Mapping()
}

class CompositeCheck extends CheckConfig {
  checks: List<CheckConfig> = List()
}

class LlmCheckRule extends CheckConfig {
  prompt: NonEmptyString
  rubric: String? = null
}
