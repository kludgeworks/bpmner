module dev.groknull.bpmner.pkl.CheckPrimitive

/// Schema for the Phase 2B check primitive system.
///
/// A `BpmnRule` (see `BpmnRule.pkl`) carries `checkPrimitive: CheckPrimitive?` and
/// `checkConfig: CheckConfig?`. When both are set, the Kotlin loader picks the matching
/// primitive class and instantiates it with the typed config. When unset, the rule is
/// skipped at load time (awaiting Phase 3 / #196).
///
/// # Why no common fields on `CheckConfig`?
///
/// Each primitive has its own structural inputs (property names, modes, regexes, …) with
/// almost nothing in common across primitives. Cross-cutting metadata — `name`,
/// `description`, `forModellers`, `forAI` — already lives on `RuleMetadata` in
/// `BpmnRule.pkl`, one level up. Repeating it on every primitive's `CheckConfig` would
/// duplicate the source of truth and create two places to keep in sync. The abstract
/// `CheckConfig` is therefore intentionally a pure marker: its job is to give
/// `BpmnRule.checkConfig` a polymorphic type so Pkl accepts any subclass.
///
/// # Why are optional fields written `T? = null` ?
///
/// `T?` is the canonical Pkl pattern for nullable / optional values, and `= null` declares
/// the default so the rule author can omit the field. Pkl evaluates the right-hand side
/// only when the rule omits the property, so the default is free.
///
/// # Why is `patternDescription` only on `PropertyPatternCheck`?
///
/// It's presentation metadata for the diagnostic emitted by *this specific primitive* (a
/// human-friendly explanation of what the regex enforces). It is not config that other
/// primitives could use, so it stays local to its primitive rather than being lifted to
/// the abstract base. Same reasoning would apply to any future presentation hints.
typealias NonEmptyString = String(!isEmpty)

/// The full set of primitive names that may appear in a rule's `checkPrimitive` field. The
/// Kotlin loader fails fast at startup on an unknown name. Two of these are composite /
/// non-deterministic (`CompositeCheck`, `LlmCheckRule`) and land later in Phase 2C.
typealias Primitive =
  "RequiredPropertyCheck"
    | "PropertyPatternCheck"
    | "VocabularyCheck"
    | "RequiredAssociationCheck"
    | "TopologyCheck"
    | "ConnectivityCheck"
    | "PairingCheck"
    | "CardinalityCheck"
    | "PoolLabelCheck"
    | "ElementConstraintCheck"
    | "PartOfSpeechCheck"
    | "LemmaCheck"
    | "GrammaticalShapeCheck"
    | "CompositeCheck"
    | "LlmCheckRule"

/// Marker base class. Exists only so `BpmnRule.checkConfig: CheckConfig?` can accept any of
/// the typed subclasses below. Intentionally empty — see the file-level doc comment.
abstract class CheckConfig

class RequiredPropertyCheck extends CheckConfig {
  property: NonEmptyString
}

class PropertyPatternCheck extends CheckConfig {
  property: NonEmptyString
  pattern: NonEmptyString

  /// Human-readable description of what `pattern` enforces, surfaced in the violation
  /// message (e.g. `"sentence case"`). Optional because some rules use a self-explanatory
  /// pattern. Local to this primitive — see the file-level doc comment.
  patternDescription: String? = null
}

class VocabularyCheck extends CheckConfig {
  property: NonEmptyString
  /// `REQUIRE` / `FORBID` check whether **any** token in the property's tokenization matches a
  /// word in [words]. `REQUIRE_LEADING` / `FORBID_LEADING` restrict the check to the **first**
  /// token only — used by leading-verb rules like `DiscouragedBusinessVerbs` whose legacy
  /// semantics matched on `name.split(/\s+/)[0]`.
  mode: "REQUIRE" | "FORBID" | "REQUIRE_LEADING" | "FORBID_LEADING"
  words: List<NonEmptyString> = List()
}

class RequiredAssociationCheck extends CheckConfig {
  association: NonEmptyString
  sourceTypes: List<NonEmptyString> = List()
  targetTypes: List<NonEmptyString> = List()
}

class TopologyCheck extends CheckConfig {
  topology: "NO_FAKE_JOIN" | "NO_SUPERFLUOUS" | "NO_JOIN_FORK" | "CONVERGING_UNNAMED"
  minIncoming: Int? = null
  maxIncoming: Int? = null
  minOutgoing: Int? = null
  maxOutgoing: Int? = null
}

class ConnectivityCheck extends CheckConfig {
  mode: "NO_INCOMING" | "FLOWS_NAMED" | "WITHIN_POOL" | "ACROSS_POOLS"
  sourceTypes: List<NonEmptyString> = List()
  targetTypes: List<NonEmptyString> = List()
}

class PairingCheck extends CheckConfig {
  mode: "ERROR_END_BOUNDARY" | "LINK_PAIRING" | "MESSAGE_START_FLOW"
  left: String? = null
  right: String? = null
}

class CardinalityCheck extends CheckConfig {
  element: NonEmptyString
  min: Int? = null
  max: Int? = null
}

class PoolLabelCheck extends CheckConfig {
  mode: NonEmptyString
}

class ElementConstraintCheck extends CheckConfig {
  element: NonEmptyString
  mode: "ALLOWED_ELEMENT_SUBSET"
    | "TIMER_EXPRESSION"
    | "PARALLEL_GATEWAY_STRUCTURE"
    | "EVENT_BASED_GATEWAY_DIRECT_EVENTS"
  constraints: Mapping<NonEmptyString, Any> = new Mapping {}
}

// --------------------------------------------------------------------------------------
// Phase 3 (#218) NLP-aware primitives. Backed by [BpmnNlp] on the Kotlin side; rules using
// these primitives consume tokenisation, POS-tagging, and lemmatisation built from a small
// hand-curated BPMN-domain lemma dictionary. See `OpenNlpBpmnNlp.kt` for the heuristics.

class PartOfSpeechCheck extends CheckConfig {
  property: NonEmptyString
  /// `LEADING_MUST_BE` fires when the leading token's POS is not [posClass] (e.g.
  /// `VerbObjectName.missingVerb` expects `VERB`). `LEADING_MUST_NOT_BE` fires when it
  /// IS [posClass]. Tokens classified as `OTHER` never fire either direction.
  mode: "LEADING_MUST_BE" | "LEADING_MUST_NOT_BE"
  /// One of the coarse POS classes exposed by `BpmnNlp`. Penn-Treebank tags are mapped to
  /// these on the Kotlin side; rule authors never see Penn tags.
  posClass: "VERB" | "NOUN" | "ADJ" | "AUX" | "WH" | "OTHER"
}

class LemmaCheck extends CheckConfig {
  property: NonEmptyString
  /// `REQUIRE_LEADING_LEMMA` / `FORBID_LEADING_LEMMA` constrain the leading token; the
  /// `*_ANY_LEMMA` variants look at every token. Lemmas are case-folded at evaluation
  /// time so authors can write them in any case.
  mode: "REQUIRE_LEADING_LEMMA" | "FORBID_LEADING_LEMMA" | "REQUIRE_ANY_LEMMA" | "FORBID_ANY_LEMMA"
  lemmas: List<NonEmptyString>
}

class GrammaticalShapeCheck extends CheckConfig {
  property: NonEmptyString
  /// `STATE_LABEL` passes for noun-led or past-participle-led labels (`Order received`).
  /// `ACTION_LABEL` passes only for action-verb-led labels (`Process the order`).
  /// `QUESTION_FORM` passes for labels starting with a WH-word or modal/copular auxiliary,
  /// or ending with `?`.
  mode: "STATE_LABEL" | "ACTION_LABEL" | "QUESTION_FORM"
}

/// CompositeCheck composes several typed deterministic sub-checks under one Pkl rule. Each
/// sub-check declares the `errorMessages` key it owns, so multi-code rules like
/// `BoundaryEventConstraints` ({detached, incoming, outgoing, errorInterrupting}) remain
/// distinct diagnostics in the engine output rather than collapsing under one code.
///
/// CompositeCheck is for *deterministic* composition only. Mixing `LlmCheckRule` sub-checks
/// is rejected at load time — LLM judgment is evaluated by the `LlmRuleAgent` (which
/// participates in the GOAP plan), while composite sub-checks run as plain function calls.
/// Nesting (`CompositeCheck` inside `CompositeCheck`) is also rejected to keep diagnostic
/// attribution unambiguous; rules needing two layers of composition should chain two
/// top-level Pkl rules instead.
class CompositeCheck extends CheckConfig {
  /// Optional element-type narrowing applied before sub-checks see the model. When non-
  /// empty, overrides the outer rule's `targetElements` for the duration of evaluation.
  targetTypes: List<NonEmptyString> = List()

  /// Ordered list of sub-checks. Each pairs a `diagnosticCode` (must exist in the parent
  /// rule's `errorMessages`) with the typed deterministic CheckConfig that emits that
  /// violation kind.
  subChecks: List<SubCheck> = List()
}

class SubCheck {
  /// Selects which key in the parent rule's `errorMessages` map this sub-check's
  /// violations are attributed to. Must NOT be `"default"` — the default key is reserved
  /// as a fallback when no sub-check matched.
  diagnosticCode: NonEmptyString

  /// The typed CheckConfig describing what this sub-check looks for. Any concrete
  /// deterministic CheckConfig subclass is allowed. `CompositeCheck` (no nesting) and
  /// `LlmCheckRule` (different evaluation tier) are both rejected at load time.
  config: CheckConfig
}

/// `LlmCheckRule` rules are evaluated by `LlmRuleAgent` (an Embabel `@Agent`), not by the
/// deterministic rule engine. The agent batches multiple `LlmCheckRule`-typed rules into a
/// single prompt per `BpmnConfig.lintBatchSize` chunk (default 10) and parses violations
/// back to per-rule diagnostics. The `rubric` is optional grading guidance appended to the
/// prompt body alongside the rule's `forAI` metadata.
class LlmCheckRule extends CheckConfig {
  prompt: NonEmptyString
  rubric: String? = null
}
