module dev.groknull.bpmner.pkl.RuleCategory

class Category {
  name: "Activity"
    | "Association"
    | "Artifact"
    | "Data"
    | "Event"
    | "Flow"
    | "Gateway"
    | "General"
    | "Lane"
    | "Message"
    | "Name"
    | "Pool"
  shortCode: String(!isEmpty) = name.toLowerCase()
}

Activity: Category = new {
  name = "Activity"
  shortCode = "act"
}

Association: Category = new {
  name = "Association"
  shortCode = "assoc"
}

Artifact: Category = new {
  name = "Artifact"
  shortCode = "art"
}

Data: Category = new {
  name = "Data"
}

Event: Category = new {
  name = "Event"
  shortCode = "evt"
}

Flow: Category = new {
  name = "Flow"
}

Gateway: Category = new {
  name = "Gateway"
  shortCode = "gtw"
}

General: Category = new {
  name = "General"
  shortCode = "gen"
}

Lane: Category = new {
  name = "Lane"
}

Message: Category = new {
  name = "Message"
  shortCode = "msg"
}

Name: Category = new {
  name = "Name"
}

Pool: Category = new {
  name = "Pool"
}
