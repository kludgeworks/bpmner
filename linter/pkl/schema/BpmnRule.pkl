import "RuleCategory.pkl"

typealias NonEmptyString = String(!isEmpty)
typealias Severity = "error" | "warning" | "info" | "off"
typealias RepairKind =
  "LOCAL_MODEL_FIX" | "LOCAL_XML_FIX" | "LLM_MODEL_PATCH" | "LLM_XML_REWRITE" | "UNFIXABLE"
typealias RepairSafety = "SAFE_AUTOMATIC" | "SAFE_MANUAL" | "LLM_ONLY"

class Repair {
  kind: RepairKind = "LLM_MODEL_PATCH"
  safety: RepairSafety = "LLM_ONLY"
  handler: String?(
    if (kind == "LOCAL_MODEL_FIX" || kind == "LOCAL_XML_FIX")
      this != null && !this.isEmpty
    else
      this == null,
  ) = null
  replacementMap: Mapping<String, String>? = null
}

name: NonEmptyString
category: RuleCategory.RuleCategory
slug: String = name.toLowerCase().replaceAll(Regex("[^a-z0-9]+"), "-")
id: String = "\(category.shortCode)-\(slug)"

intent: NonEmptyString
forModellers: NonEmptyString
forAI: NonEmptyString

targetElements: List<NonEmptyString>(!isEmpty)
severity: Severity = "warning"
errorMessages: Mapping<NonEmptyString, NonEmptyString>(!isEmpty)
staticConfig: Dynamic? = null

repair: Repair = new {}

hasTsImplementation: Boolean = true

aliases: List<NonEmptyString> = List()
deprecated: Boolean = false
replacedBy: List<String> = List()
deprecationReason: String?(if (deprecated) this != null else true) = null
