amends "pkl:test"

import "../schema/RuleCategory.pkl"
import "UncommonAbbreviations.pkl" as Rule

facts {
  ["NAME-02 ID is generated from category, sequence, and name"] {
    Rule.id == "name-02-uncommon-abbreviations"
    Rule.slug == "uncommon-abbreviations"
  }

  ["NAME-02 preserves cookbook category metadata"] {
    Rule.category.name == "Name"
    Rule.category.shortCode == "name"
    Rule.sequence == 2
  }

  ["category short codes default to lowercase names unless overridden"] {
    RuleCategory.Flow.shortCode == "flow"
    RuleCategory.Pool.shortCode == "pool"
    RuleCategory.Event.shortCode == "evt"
    RuleCategory.Gateway.shortCode == "gtw"
  }

  ["NAME-02 carries linter and auto-fix metadata"] {
    Rule.severity == "warning"
    Rule.targetElements.contains("bpmn:Task")
    Rule.errorMessages["default"]
      == "Avoid uncommon abbreviations in labels or explain them via annotation/glossary"
    Rule.staticConfig.commonAcronyms.contains("BPMN")
    !Rule.autoFixable
    Rule.fixStrategy == "none"
  }
}
