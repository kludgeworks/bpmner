itionExpression></sequenceFlow><sequenceFlow id="Flow_5" sourceRef="act-extract-contract" targetRef="act-validate-contract" /><sequenceFlow id="Flow_6" sourceRef="act-validate-contract" targetRef="dec-contract-valid" /><sequenceFlow id="Flow_7" name="Contract valid" sourceRef="dec-contract-valid" targetRef="act-create-outline"><conditionExpression id="conditionExpression_a2246fec-8aba-4e7d-8f46-782f42b047fd">ValidatedProcessContract has no issues</conditionExpression></sequenceFlow><sequenceFlow id="Flow_8" name="Contract invalid" sourceRef="dec-contract-valid" targetRef="end-aborted-invalid-contract"><conditionExpression id="conditionExpression_03ba4388-0e41-4cb3-a6e7-fa06a10ae388">ValidatedProcessContract contains formatted issues</conditionExpression></sequenceFlow><sequenceFlow id="Flow_9" sourceRef="act-create-outline" targetRef="act-validate-outline" /><sequenceFlow id="Flow_10" sourceRef="act-validate-outline" targetRef="act-generate-phase-plans" /><sequenceFlow id="Flow_11" sourceRef="act-generate-phase-plans" targetRef="act-compose-graph" /><sequenceFlow id="Flow_12" sourceRef="act-compose-graph" targetRef="act-assign-ownership" /><sequenceFlow id="Flow_13" sourceRef="act-assign-ownership" targetRef="act-assign-layout" /><sequenceFlow id="Flow_14" sourceRef="act-assign-layout" targetRef="act-render-bpmn-xml" /><sequenceFlow id="Flow_15" sourceRef="act-render-bpmn-xml" targetRef="Gateway_join_1" /><sequenceFlow id="Flow_16" sourceRef="act-validate-and-repair" targetRef="dec-repair-outcome" /><sequenceFlow id="Flow_17" name="Validation passed" sourceRef="dec-repair-outcome" targetRef="act-auto-fix-xml"><conditionExpression id="conditionExpression_f5f521d6-5fbe-479f-9ac3-217762419531">XML passes XSD and bpmn-lint</conditionExpression></sequenceFlow><sequenceFlow id="Flow_18" name="Validation failed — retry repair" sourceRef="dec-repair-outcome" targetRef="Gateway_join_1"><conditionExpression id="conditionExpression_03f88110-e96b-4a13-a537-1cd49fda13fd">XML fai