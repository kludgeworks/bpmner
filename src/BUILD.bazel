    main_class = "dev.groknull.bpmner.NativeBpmnerApplication",
    reflection_configuration = "native-config/META-INF/native-image/dev.groknull.bpmner/reflect-config.json",
    tags = ["local"],
    deps = [
        ":bpmner_aot_lib",
        ":bpmner_aot_resources",
        ":bpmner_core",
        ":bpmner_native_config_resources",
        ":native_launcher",
    ],
