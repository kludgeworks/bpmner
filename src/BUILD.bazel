genrule(
    name = "bpmner_aot_sources",
    outs = [
        "aot_sources.srcjar",
        "aot_resources.jar",
        "aot_classes.jar",
    ],
    cmd = """
    set -euo pipefail

    mkdir -p aot_tmp/sources
    mkdir -p aot_tmp/resources
    mkdir -p aot_tmp/classes

    # Run the AOT processor
    $(location :aot_processor) \
      dev.groknull.bpmner.BpmnerApplicationKt \
      aot_tmp/sources \
      aot_tmp/resources \
      aot_tmp/classes \
      dev.groknull.bpmner \
      bpmner \
      --spring.profiles.active=githubmodels \
      --spring.threads.virtual.enabled=false

    # Package sources into a srcjar
    source_args=()
    while IFS= read -r file; do
      rel="$${file#./}"
      source_args+=("$${rel}=aot_tmp/sources/$${rel}")
    done < <(cd aot_tmp/sources && find . -type f | sort)
    $(location @bazel_tools//tools/zip:zipper) c $(location aot_sources.srcjar) "$${source_args[@]}"

    # Package resources into a jar
    resource_args=()
    while IFS= read -r file; do
      rel="$${file#./}"
      resource_args+=("$${rel}=aot_tmp/resources/$${rel}")
    done < <(cd aot_tmp/resources && find . -type f | sort)
    $(location @bazel_tools//tools/zip:zipper) c $(location aot_resources.jar) "$${resource_args[@]}"

    # Package generated classes into a jar
    class_args=()
    while IFS= read -r file; do
      rel="$${file#./}"
      class_args+=("$${rel}=aot_tmp/classes/$${rel}")
    done < <(cd aot_tmp/classes && find . -type f | sort)
    $(location @bazel_tools//tools/zip:zipper) c $(location aot_classes.jar) "$${class_args[@]}"
    """,
    tools = [
        ":aot_processor",
        "@bazel_tools//tools/zip:zipper",
    ],
)

