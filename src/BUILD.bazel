genrule(
    name = "native_launcher_sources",
    outs = ["native_launcher.srcjar"],
    cmd = """
    mkdir -p native_launcher_src/dev/groknull/bpmner
    cat > native_launcher_src/dev/groknull/bpmner/NativeBpmnerApplication.java <<'EOF'
package dev.groknull.bpmner;

import java.util.ArrayList;
import java.util.List;

/** Native-image launcher that keeps Spring property options out of Spring Shell command args. */
public final class NativeBpmnerApplication {
  private NativeBpmnerApplication() {}

  public static void main(String[] args) {
    List<String> applicationArgs = new ArrayList<>();
    for (String arg : args) {
      if (arg.startsWith("--") && arg.contains("=")) {
        String property = arg.substring(2);
        int separator = property.indexOf('=');
        String key = property.substring(0, separator);
        if (key.contains(".")) {
          System.setProperty(key, property.substring(separator + 1));
        } else {
          applicationArgs.add(arg);
        }
      } else {
        applicationArgs.add(arg);
      }
    }
    BpmnerApplicationKt.main(applicationArgs.toArray(String[]::new));
  }
}
EOF
    $(location @bazel_tools//tools/zip:zipper) c $(location native_launcher.srcjar) \
      dev/groknull/bpmner/NativeBpmnerApplication.java=native_launcher_src/dev/groknull/bpmner/NativeBpmnerApplication.java
    """,
    tools = ["@bazel_tools//tools/zip:zipper"],
)

