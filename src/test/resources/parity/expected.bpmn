<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" exporter="bpmner" exporterVersion="0.0.1" id="definitions_f5147f13-24ef-464b-9e90-f16080a89ad9" targetNamespace="https://groknull.dev/bpmner">
  <bpmn:message xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Message_CreditApplication" name="Credit Application"/><bpmn:collaboration xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Collaboration_Process_credit_application"><bpmn:participant id="Participant_credit_application" name="Credit Application Process" processRef="Process_credit_application"/></bpmn:collaboration><process camunda:historyTimeToLive="P180D" id="Process_credit_application" isExecutable="true" name="Credit Application Process"><bpmn:laneSet xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="LaneSet_Process_credit_application"><bpmn:lane id="Lane_system" name="System"><bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef><bpmn:flowNodeRef>act-run-credit-check</bpmn:flowNodeRef><bpmn:flowNodeRef>dec-credit-score-check</bpmn:flowNodeRef><bpmn:flowNodeRef>act-auto-approve</bpmn:flowNodeRef><bpmn:flowNodeRef>end-approved</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_underwriter" name="Underwriter"><bpmn:flowNodeRef>act-underwriter-review</bpmn:flowNodeRef><bpmn:flowNodeRef>end-reviewed</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet>
    <startEvent id="StartEvent_1" name="Credit application received">
      <outgoing>Flow_1</outgoing>
    <bpmn:messageEventDefinition xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" messageRef="Message_CreditApplication"/></startEvent>
    <serviceTask id="act-run-credit-check" name="Run credit check">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    <bpmn:dataInputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_1"><bpmn:sourceRef>art-credit-application</bpmn:sourceRef><bpmn:targetRef>act-run-credit-check</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_2"><bpmn:sourceRef>act-run-credit-check</bpmn:sourceRef><bpmn:targetRef>art-credit-score</bpmn:targetRef></bpmn:dataOutputAssociation></serviceTask>
    <exclusiveGateway default="Flow_4" id="dec-credit-score-check" name="Credit score sufficient?">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
      <outgoing>Flow_4</outgoing>
    </exclusiveGateway>
    <serviceTask id="act-auto-approve" name="Auto-approve application">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_5</outgoing>
    <bpmn:dataInputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_3"><bpmn:sourceRef>art-credit-score</bpmn:sourceRef><bpmn:targetRef>act-auto-approve</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_4"><bpmn:sourceRef>act-auto-approve</bpmn:sourceRef><bpmn:targetRef>art-approval-decision</bpmn:targetRef></bpmn:dataOutputAssociation></serviceTask>
    <userTask id="act-underwriter-review" name="Review application">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_6</outgoing>
    <bpmn:dataInputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_5"><bpmn:sourceRef>art-credit-application</bpmn:sourceRef><bpmn:targetRef>act-underwriter-review</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_6"><bpmn:sourceRef>art-credit-score</bpmn:sourceRef><bpmn:targetRef>act-underwriter-review</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="DataAssoc_7"><bpmn:sourceRef>act-underwriter-review</bpmn:sourceRef><bpmn:targetRef>art-approval-decision</bpmn:targetRef></bpmn:dataOutputAssociation></userTask>
    <endEvent id="end-approved" name="Application approved">
      <incoming>Flow_5</incoming>
    </endEvent>
    <endEvent id="end-reviewed" name="Application reviewed by underwriter">
      <incoming>Flow_6</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="act-run-credit-check"/>
    <sequenceFlow id="Flow_2" sourceRef="act-run-credit-check" targetRef="dec-credit-score-check"/>
    <sequenceFlow id="Flow_3" name="Score &gt;= 700" sourceRef="dec-credit-score-check" targetRef="act-auto-approve">
      <conditionExpression id="conditionExpression_39de0e68-3160-4819-b432-50cf3613e5b7">credit score &gt;= 700</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_4" name="Score &lt; 700" sourceRef="dec-credit-score-check" targetRef="act-underwriter-review"/>
    <sequenceFlow id="Flow_5" sourceRef="act-auto-approve" targetRef="end-approved"/>
    <sequenceFlow id="Flow_6" sourceRef="act-underwriter-review" targetRef="end-reviewed"/>
  <bpmn:dataObject xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="art-credit-application" name="Credit Application"/><bpmn:dataObject xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="art-credit-score" name="Credit Score"/><bpmn:dataObject xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="art-approval-decision" name="Approval Decision"/></process>
<bpmndi:BPMNDiagram id="BPMNDiagram_Collaboration_Process_credit_application"><bpmndi:BPMNPlane bpmnElement="Collaboration_Process_credit_application" id="BPMNPlane_Collaboration_Process_credit_application"><bpmndi:BPMNShape bpmnElement="Participant_credit_application" id="Participant_credit_application_di"><dc:Bounds height="560" width="960" x="0" y="0"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="Lane_underwriter" id="Lane_underwriter_di"><dc:Bounds height="280" width="930" x="30" y="280"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="Lane_system" id="Lane_system_di"><dc:Bounds height="280" width="930" x="30" y="0"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="StartEvent_1" id="StartEvent_1_di"><dc:Bounds height="36" width="36" x="192" y="122"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="act-run-credit-check" id="act-run-credit-check_di"><dc:Bounds height="80" width="100" x="310" y="100"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="dec-credit-score-check" id="dec-credit-score-check_di" isMarkerVisible="true"><dc:Bounds height="50" width="50" x="485" y="115"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="act-auto-approve" id="act-auto-approve_di"><dc:Bounds height="80" width="100" x="610" y="100"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="act-underwriter-review" id="act-underwriter-review_di"><dc:Bounds height="80" width="100" x="610" y="380"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="end-approved" id="end-approved_di"><dc:Bounds height="36" width="36" x="792" y="122"/></bpmndi:BPMNShape><bpmndi:BPMNShape bpmnElement="end-reviewed" id="end-reviewed_di"><dc:Bounds height="36" width="36" x="792" y="402"/></bpmndi:BPMNShape><bpmndi:BPMNEdge bpmnElement="Flow_1" id="Flow_1_di"><di:waypoint x="228" y="140"/><di:waypoint x="310" y="140"/></bpmndi:BPMNEdge><bpmndi:BPMNEdge bpmnElement="Flow_2" id="Flow_2_di"><di:waypoint x="410" y="140"/><di:waypoint x="485" y="140"/></bpmndi:BPMNEdge><bpmndi:BPMNEdge bpmnElement="Flow_3" id="Flow_3_di"><di:waypoint x="535" y="140"/><di:waypoint x="610" y="140"/></bpmndi:BPMNEdge><bpmndi:BPMNEdge bpmnElement="Flow_4" id="Flow_4_di"><di:waypoint x="510" y="165"/><di:waypoint x="510" y="420"/><di:waypoint x="610" y="420"/></bpmndi:BPMNEdge><bpmndi:BPMNEdge bpmnElement="Flow_5" id="Flow_5_di"><di:waypoint x="710" y="140"/><di:waypoint x="792" y="140"/></bpmndi:BPMNEdge><bpmndi:BPMNEdge bpmnElement="Flow_6" id="Flow_6_di"><di:waypoint x="710" y="420"/><di:waypoint x="792" y="420"/></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></definitions>