<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://example.com/bpmn"
             exporter="bpmner" exporterVersion="1.0">

  <process id="order-fulfillment" name="Order Fulfillment" isExecutable="false">
    <startEvent id="start" name="Order Received">
      <outgoing>flow1</outgoing>
    </startEvent>
    <sequenceFlow id="flow1" sourceRef="start" targetRef="task-pick"/>
    <task id="task-pick" name="Pick Items from Warehouse">
      <incoming>flow1</incoming>
      <outgoing>flow2</outgoing>
    </task>
    <sequenceFlow id="flow2" sourceRef="task-pick" targetRef="task-pack"/>
    <task id="task-pack" name="Pack Order">
      <incoming>flow2</incoming>
      <outgoing>flow3</outgoing>
    </task>
    <sequenceFlow id="flow3" sourceRef="task-pack" targetRef="task-ship"/>
    <task id="task-ship" name="Ship Order">
      <incoming>flow3</incoming>
      <outgoing>flow4</outgoing>
    </task>
    <sequenceFlow id="flow4" sourceRef="task-ship" targetRef="end"/>
    <endEvent id="end" name="Order Shipped">
      <incoming>flow4</incoming>
    </endEvent>
  </process>
</definitions>
