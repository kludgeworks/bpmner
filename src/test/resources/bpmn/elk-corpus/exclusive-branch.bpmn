<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  id="Definitions_xor" targetNamespace="https://groknull.dev/bpmner">
  <bpmn:process id="Process_xor" name="Exclusive Branch" isExecutable="true">
    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gw_split" name="Approved?">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_yes" name="Fulfil Order">
      <bpmn:incoming>Flow_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_join_yes</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_no" name="Reject Order">
      <bpmn:incoming>Flow_no</bpmn:incoming>
      <bpmn:outgoing>Flow_join_no</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_join">
      <bpmn:incoming>Flow_join_yes</bpmn:incoming>
      <bpmn:incoming>Flow_join_no</bpmn:incoming>
      <bpmn:outgoing>Flow_end</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_1" name="Order Closed">
      <bpmn:incoming>Flow_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Gw_split"/>
    <bpmn:sequenceFlow id="Flow_yes" name="Yes" sourceRef="Gw_split" targetRef="Task_yes"/>
    <bpmn:sequenceFlow id="Flow_no" name="No" sourceRef="Gw_split" targetRef="Task_no"/>
    <bpmn:sequenceFlow id="Flow_join_yes" sourceRef="Task_yes" targetRef="Gw_join"/>
    <bpmn:sequenceFlow id="Flow_join_no" sourceRef="Task_no" targetRef="Gw_join"/>
    <bpmn:sequenceFlow id="Flow_end" sourceRef="Gw_join" targetRef="End_1"/>
  </bpmn:process>
</bpmn:definitions>
