<?xml version="1.0" encoding="UTF-8"?>
<!-- STATUS: VALIDATED (human-reviewed in bpmn-js, 2026-07-12) — original review notes: open in https://demo.bpmn.io/ and confirm:
     1. The subprocess box is visible and expanded.
     2. The XOR split gateway and both branch tasks are inside the subprocess box.
     3. The XOR join gateway is inside the subprocess box.
     4. Both branch edges are routed inside the subprocess box — not passing outside it.
     5. The outer start, outer task, and outer end are outside the subprocess box.
     6. All shapes on the main flow are vertically centred on the same horizontal line.
     7. The two branch tasks are on separate horizontal rows above and below the centre line,
        with the gateways on the centre line.
-->
<!--
  COORDINATE TABLE  (gateway/event centre line: y=200)
  ─────────────────────────────────────────────────────────────────────────────
  Shape               x      y     w    h    cx    cy    right
  ─────────────────────────────────────────────────────────────────────────────
  Start_1            80    182    36   36    98   200      116
  Task_outer        166    160   100   80   216   200      266
  SubProcess_1      316     40   480  320   556   200      796
    SubStart        366    182    36   36   384   200      402
    Gw_split        452    175    50   50   477   200      502
    Task_upper      562     90   100   80   612   130      662   ← upper branch, ±70px from centre
    Task_lower      562    230   100   80   612   270      662   ← lower branch, ±70px from centre
    Gw_join         712    175    50   50   737   200      762
    SubEnd          778    182    36   36   796   200      814   ← centre at subprocess right edge (796)
  Task_outer2       864    160   100   80   914   200      964   ← 50px right of SubEnd right (814+50)
  End_1            1014    182    36   36  1032   200     1050   ← 50px right of Task_outer2 right (964+50)
  ─────────────────────────────────────────────────────────────────────────────
  Subprocess box: x=316, y=40, w=480, h=320 → right edge x=796, centre y=200.
  SubEnd centre x=796 → straddles the right border.
  Upper/lower branch tasks symmetric ±70px from centre line (cx y=130 and y=270).
  50px clear from subprocess top (y=40+50=90) and bottom (y=360-50=310) for both tasks.
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ref_subprocess_branch"
                  targetNamespace="https://groknull.dev/bpmner">

  <bpmn:process id="Process_1" name="Subprocess Branch Reference" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_outer" name="Prepare">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_to_sub</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:subProcess id="SubProcess_1" name="Decide and Act">
      <bpmn:incoming>Flow_to_sub</bpmn:incoming>
      <bpmn:outgoing>Flow_from_sub</bpmn:outgoing>

      <bpmn:startEvent id="SubStart" name="Begin">
        <bpmn:outgoing>SubFlow_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="Gw_split" name="Which path?">
        <bpmn:incoming>SubFlow_1</bpmn:incoming>
        <bpmn:outgoing>SubFlow_upper</bpmn:outgoing>
        <bpmn:outgoing>SubFlow_lower</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:serviceTask id="Task_upper" name="Path A">
        <bpmn:incoming>SubFlow_upper</bpmn:incoming>
        <bpmn:outgoing>SubFlow_upper_join</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_lower" name="Path B">
        <bpmn:incoming>SubFlow_lower</bpmn:incoming>
        <bpmn:outgoing>SubFlow_lower_join</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:exclusiveGateway id="Gw_join">
        <bpmn:incoming>SubFlow_upper_join</bpmn:incoming>
        <bpmn:incoming>SubFlow_lower_join</bpmn:incoming>
        <bpmn:outgoing>SubFlow_end</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="SubEnd" name="Done">
        <bpmn:incoming>SubFlow_end</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="SubFlow_1"          sourceRef="SubStart"   targetRef="Gw_split"/>
      <bpmn:sequenceFlow id="SubFlow_upper"       sourceRef="Gw_split"   targetRef="Task_upper"/>
      <bpmn:sequenceFlow id="SubFlow_lower"       sourceRef="Gw_split"   targetRef="Task_lower"/>
      <bpmn:sequenceFlow id="SubFlow_upper_join"  sourceRef="Task_upper" targetRef="Gw_join"/>
      <bpmn:sequenceFlow id="SubFlow_lower_join"  sourceRef="Task_lower" targetRef="Gw_join"/>
      <bpmn:sequenceFlow id="SubFlow_end"         sourceRef="Gw_join"    targetRef="SubEnd"/>
    </bpmn:subProcess>

    <bpmn:userTask id="Task_outer2" name="Review">
      <bpmn:incoming>Flow_from_sub</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="End_1" name="End">
      <bpmn:incoming>Flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1"        sourceRef="Start_1"     targetRef="Task_outer"/>
    <bpmn:sequenceFlow id="Flow_to_sub"   sourceRef="Task_outer"  targetRef="SubProcess_1"/>
    <bpmn:sequenceFlow id="Flow_from_sub" sourceRef="SubProcess_1" targetRef="Task_outer2"/>
    <bpmn:sequenceFlow id="Flow_to_end"   sourceRef="Task_outer2" targetRef="End_1"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <!-- Start_1: centre (98, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="80" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="66" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_outer: centre (216, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_Task_outer" bpmnElement="Task_outer">
        <dc:Bounds x="166" y="160" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="191" y="193" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SubProcess_1: x=316, y=40, w=480, h=320 → centre (556, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_SubProcess_1" bpmnElement="SubProcess_1" isExpanded="true">
        <dc:Bounds x="316" y="40" width="480" height="320"/>
        <bpmndi:BPMNLabel><dc:Bounds x="506" y="44" width="100" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SubStart: centre (384, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_SubStart" bpmnElement="SubStart">
        <dc:Bounds x="366" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="352" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gw_split: centre (477, 200) — 50×50, x=452, y=175 -->
      <bpmndi:BPMNShape id="BPMNShape_Gw_split" bpmnElement="Gw_split">
        <dc:Bounds x="452" y="175" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="438" y="232" width="78" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_upper: centre (612, 130) — upper branch, symmetric +70px above centre -->
      <bpmndi:BPMNShape id="BPMNShape_Task_upper" bpmnElement="Task_upper">
        <dc:Bounds x="562" y="90" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="587" y="123" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_lower: centre (612, 270) — lower branch, symmetric -70px below centre -->
      <bpmndi:BPMNShape id="BPMNShape_Task_lower" bpmnElement="Task_lower">
        <dc:Bounds x="562" y="230" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="587" y="263" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gw_join: centre (737, 200) — 50×50, x=712, y=175 -->
      <bpmndi:BPMNShape id="BPMNShape_Gw_join" bpmnElement="Gw_join">
        <dc:Bounds x="712" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- SubEnd: centre (796, 200) — straddles subprocess right edge at x=796 -->
      <bpmndi:BPMNShape id="BPMNShape_SubEnd" bpmnElement="SubEnd">
        <dc:Bounds x="778" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="764" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_outer2: centre (914, 200) — 50px right of SubEnd right (814+50=864) -->
      <bpmndi:BPMNShape id="BPMNShape_Task_outer2" bpmnElement="Task_outer2">
        <dc:Bounds x="864" y="160" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="889" y="193" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End_1: centre (1032, 200) — 50px right of Task_outer2 right (964+50=1014) -->
      <bpmndi:BPMNShape id="BPMNShape_End_1" bpmnElement="End_1">
        <dc:Bounds x="1014" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1007" y="225" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Outer edges — all at y=200 -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="116" y="200"/>
        <di:waypoint x="166" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_to_sub" bpmnElement="Flow_to_sub">
        <di:waypoint x="266" y="200"/>
        <di:waypoint x="316" y="200"/>
      </bpmndi:BPMNEdge>
      <!-- Flow_from_sub: SubEnd right (814) → Task_outer2 left (864) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_from_sub" bpmnElement="Flow_from_sub">
        <di:waypoint x="814" y="200"/>
        <di:waypoint x="864" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_to_end" bpmnElement="Flow_to_end">
        <di:waypoint x="964" y="200"/>
        <di:waypoint x="1014" y="200"/>
      </bpmndi:BPMNEdge>

      <!-- Inner edges -->
      <!-- SubStart → Gw_split: straight at y=200 -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_1" bpmnElement="SubFlow_1">
        <di:waypoint x="402" y="200"/>
        <di:waypoint x="452" y="200"/>
      </bpmndi:BPMNEdge>

      <!-- Gw_split → Task_upper: from gateway top (477,175) up to task left at cy=130 -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_upper" bpmnElement="SubFlow_upper">
        <di:waypoint x="477" y="175"/>
        <di:waypoint x="477" y="130"/>
        <di:waypoint x="562" y="130"/>
      </bpmndi:BPMNEdge>

      <!-- Gw_split → Task_lower: from gateway bottom (477,225) down to task left at cy=270 -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_lower" bpmnElement="SubFlow_lower">
        <di:waypoint x="477" y="225"/>
        <di:waypoint x="477" y="270"/>
        <di:waypoint x="562" y="270"/>
      </bpmndi:BPMNEdge>

      <!-- Task_upper → Gw_join: right of task (662,130) → across then down to join top (737,175) -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_upper_join" bpmnElement="SubFlow_upper_join">
        <di:waypoint x="662" y="130"/>
        <di:waypoint x="737" y="130"/>
        <di:waypoint x="737" y="175"/>
      </bpmndi:BPMNEdge>

      <!-- Task_lower → Gw_join: right of task (662,270) → across then up to join bottom (737,225) -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_lower_join" bpmnElement="SubFlow_lower_join">
        <di:waypoint x="662" y="270"/>
        <di:waypoint x="737" y="270"/>
        <di:waypoint x="737" y="225"/>
      </bpmndi:BPMNEdge>

      <!-- Gw_join → SubEnd: straight at y=200, to SubEnd left (778) -->
      <bpmndi:BPMNEdge id="BPMNEdge_SubFlow_end" bpmnElement="SubFlow_end">
        <di:waypoint x="762" y="200"/>
        <di:waypoint x="778" y="200"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
