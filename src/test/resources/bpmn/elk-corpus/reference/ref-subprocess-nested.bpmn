<?xml version="1.0" encoding="UTF-8"?>
<!-- STATUS: VALIDATED (human-reviewed in bpmn-js, 2026-07-12) — original review notes: open in https://demo.bpmn.io/ and confirm:
     1. The outer subprocess box is visible and expanded.
     2. The inner subprocess box is visible, expanded, and sits INSIDE the outer box.
     3. The grandchild task ("Do Work") is INSIDE the inner subprocess box.
     4. All shapes at each level are vertically centred within their container.
     5. No shape overlaps its parent boundary — nesting is visually clear at all three levels.
     6. There is a line from Start to the outer subprocess box.
     7. There is a line from the outer subprocess box to End.
     8. Sequence flows at each level are contained within their respective box.
-->
<!--
  COORDINATE TABLE  (all centres on y=200)
  ─────────────────────────────────────────────────────────────────────
  Shape                  x     y     w    h    cx    cy    right
  ─────────────────────────────────────────────────────────────────────
  Start_1               80   182    36   36    98   200      116
  SubProcess_outer     166    80   602  240   467   200      768
    OuterStart         216   182    36   36   234   200      252
    SubProcess_inner   312   120   320  160   472   200      632
      InnerStart       352   182    36   36   370   200      388
      GrandchildTask   438   160   100   80   488   200      538
      InnerEnd         588   182    36   36   606   200      624
    OuterEnd           682   182    36   36   700   200      718
  End_1                818   182    36   36   836   200      854
  ─────────────────────────────────────────────────────────────────────
  Inner box:  y=120, h=160 → spans 120→280, centre 200. Padding ~40px top/bottom.
  Outer box:  y=80,  h=240 → spans  80→320, centre 200. Padding ~40px top/bottom.
  Outer box right edge (768) clears OuterEnd right (718) by 50px.
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ref_subprocess_nested"
                  targetNamespace="https://groknull.dev/bpmner">

  <bpmn:process id="Process_1" name="Nested Subprocess Reference" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:subProcess id="SubProcess_outer" name="Outer">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>

      <bpmn:startEvent id="OuterStart" name="Begin">
        <bpmn:outgoing>OuterFlow_1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:subProcess id="SubProcess_inner" name="Inner">
        <bpmn:incoming>OuterFlow_1</bpmn:incoming>
        <bpmn:outgoing>OuterFlow_2</bpmn:outgoing>

        <bpmn:startEvent id="InnerStart" name="Begin">
          <bpmn:outgoing>InnerFlow_1</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:serviceTask id="GrandchildTask" name="Do Work">
          <bpmn:incoming>InnerFlow_1</bpmn:incoming>
          <bpmn:outgoing>InnerFlow_2</bpmn:outgoing>
        </bpmn:serviceTask>
        <bpmn:endEvent id="InnerEnd" name="Done">
          <bpmn:incoming>InnerFlow_2</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="InnerFlow_1" sourceRef="InnerStart"    targetRef="GrandchildTask"/>
        <bpmn:sequenceFlow id="InnerFlow_2" sourceRef="GrandchildTask" targetRef="InnerEnd"/>
      </bpmn:subProcess>

      <bpmn:endEvent id="OuterEnd" name="Done">
        <bpmn:incoming>OuterFlow_2</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OuterFlow_1" sourceRef="OuterStart"      targetRef="SubProcess_inner"/>
      <bpmn:sequenceFlow id="OuterFlow_2" sourceRef="SubProcess_inner" targetRef="OuterEnd"/>
    </bpmn:subProcess>

    <bpmn:endEvent id="End_1" name="End">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1"        targetRef="SubProcess_outer"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="SubProcess_outer" targetRef="End_1"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <!-- Start_1: centre (98, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="80" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="66" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SubProcess_outer: x=166, y=80, w=602, h=240 → centre (467, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_SubProcess_outer" bpmnElement="SubProcess_outer" isExpanded="true">
        <dc:Bounds x="166" y="80" width="602" height="240"/>
        <bpmndi:BPMNLabel><dc:Bounds x="440" y="84" width="54" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- OuterStart: centre (234, 200) — 50px inset from outer left (166+50=216) -->
      <bpmndi:BPMNShape id="BPMNShape_OuterStart" bpmnElement="OuterStart">
        <dc:Bounds x="216" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="202" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SubProcess_inner: x=312, y=120, w=320, h=160 → centre (472, 200) -->
      <bpmndi:BPMNShape id="BPMNShape_SubProcess_inner" bpmnElement="SubProcess_inner" isExpanded="true">
        <dc:Bounds x="312" y="120" width="320" height="160"/>
        <bpmndi:BPMNLabel><dc:Bounds x="442" y="124" width="60" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- InnerStart: centre (370, 200) — 40px inset from inner left (312+40=352) -->
      <bpmndi:BPMNShape id="BPMNShape_InnerStart" bpmnElement="InnerStart">
        <dc:Bounds x="352" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="338" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- GrandchildTask: centre (488, 200) — 50px right of InnerStart right (388+50=438) -->
      <bpmndi:BPMNShape id="BPMNShape_GrandchildTask" bpmnElement="GrandchildTask">
        <dc:Bounds x="438" y="160" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="453" y="193" width="70" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- InnerEnd: centre (632, 200) — straddles inner subprocess right edge (312+320=632) -->
      <bpmndi:BPMNShape id="BPMNShape_InnerEnd" bpmnElement="InnerEnd">
        <dc:Bounds x="614" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="600" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- OuterEnd: centre (768, 200) — straddles outer subprocess right edge (166+602=768) -->
      <bpmndi:BPMNShape id="BPMNShape_OuterEnd" bpmnElement="OuterEnd">
        <dc:Bounds x="750" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="736" y="225" width="65" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End_1: centre (836, 200) — 50px right of outer right (768+50=818) -->
      <bpmndi:BPMNShape id="BPMNShape_End_1" bpmnElement="End_1">
        <dc:Bounds x="818" y="182" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="811" y="225" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Outer process edges — all at y=200 -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="116" y="200"/>
        <di:waypoint x="166" y="200"/>
      </bpmndi:BPMNEdge>
      <!-- OuterEnd right (786) → End_1 left (818) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="786" y="200"/>
        <di:waypoint x="818" y="200"/>
      </bpmndi:BPMNEdge>

      <!-- Outer subprocess internal edges — all at y=200 -->
      <bpmndi:BPMNEdge id="BPMNEdge_OuterFlow_1" bpmnElement="OuterFlow_1">
        <di:waypoint x="252" y="200"/>
        <di:waypoint x="312" y="200"/>
      </bpmndi:BPMNEdge>
      <!-- InnerEnd right (650) → OuterEnd left (750) -->
      <bpmndi:BPMNEdge id="BPMNEdge_OuterFlow_2" bpmnElement="OuterFlow_2">
        <di:waypoint x="650" y="200"/>
        <di:waypoint x="750" y="200"/>
      </bpmndi:BPMNEdge>

      <!-- Inner subprocess internal edges — all at y=200 -->
      <bpmndi:BPMNEdge id="BPMNEdge_InnerFlow_1" bpmnElement="InnerFlow_1">
        <di:waypoint x="388" y="200"/>
        <di:waypoint x="438" y="200"/>
      </bpmndi:BPMNEdge>
      <!-- GrandchildTask right (538) → InnerEnd left (614) -->
      <bpmndi:BPMNEdge id="BPMNEdge_InnerFlow_2" bpmnElement="InnerFlow_2">
        <di:waypoint x="538" y="200"/>
        <di:waypoint x="614" y="200"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
