<?xml version="1.0" encoding="UTF-8"?>
<!-- STATUS: VALIDATED (human-reviewed in bpmn-js, 2026-07-12) — original review notes: open in https://demo.bpmn.io/ and confirm:
     1. The timer boundary event (clock icon) sits on the bottom edge of "Process Order",
        roughly centred horizontally, partially overlapping the task border.
     2. An exception flow exits downward from the boundary circle to an end event below.
     3. The normal flow continues right from "Process Order" to "Ship Order" to the end.
     4. The two end events are clearly separated — one on the normal path, one on the
        exception path.
     5. No shapes overlap except the boundary circle intentionally sitting on the task edge.
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ref_boundary_timer"
                  targetNamespace="https://groknull.dev/bpmner">

  <bpmn:process id="Process_1" name="Boundary Timer Reference" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="Order Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Host task for the boundary event -->
    <bpmn:serviceTask id="Task_process" name="Process Order">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_normal</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Timer boundary on Task_process — interrupting -->
    <bpmn:boundaryEvent id="Boundary_timer" name="Timeout" attachedToRef="Task_process" cancelActivity="true">
      <bpmn:outgoing>Flow_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_1"/>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_ship" name="Ship Order">
      <bpmn:incoming>Flow_normal</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_ok" name="Order Shipped">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Exception path: timeout → cancel order → end -->
    <bpmn:serviceTask id="Task_cancel" name="Cancel Order">
      <bpmn:incoming>Flow_timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_timeout" name="Order Cancelled">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1"       sourceRef="Start_1"      targetRef="Task_process"/>
    <bpmn:sequenceFlow id="Flow_normal"  sourceRef="Task_process"  targetRef="Task_ship"/>
    <bpmn:sequenceFlow id="Flow_2"       sourceRef="Task_ship"     targetRef="End_ok"/>
    <bpmn:sequenceFlow id="Flow_timeout" sourceRef="Boundary_timer" targetRef="Task_cancel"/>
    <bpmn:sequenceFlow id="Flow_3"       sourceRef="Task_cancel"   targetRef="End_timeout"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <!--
        Centre line for normal path: y=120 (tasks 100×80 at y=80; events 36×36 at y=102).
        All waypoints on the normal path use y=120. Exception path centre line: y=290
        (tasks at y=250; end event 36×36 at y=272).
      -->

      <!-- Start_1: 36×36, y=102 → centre y=120 -->
      <bpmndi:BPMNShape id="BPMNShape_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="80" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="56" y="145" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_process: 100×80, y=80 → centre y=120 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_process" bpmnElement="Task_process">
        <dc:Bounds x="166" y="80" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="181" y="113" width="70" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Boundary_timer: 36×36, sits on the bottom edge of Task_process (y=160).
           Centre at x=216 (task horizontal centre), y=160 (task bottom edge).
           Top-left: x=198, y=142 — straddles the bottom edge. -->
      <bpmndi:BPMNShape id="BPMNShape_Boundary_timer" bpmnElement="Boundary_timer">
        <dc:Bounds x="198" y="142" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="192" y="185" width="47" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task_ship: 100×80, y=80 → centre y=120 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_ship" bpmnElement="Task_ship">
        <dc:Bounds x="316" y="80" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="334" y="113" width="64" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End_ok: 36×36, y=102 → centre y=120 (aligned with Start_1 and both tasks) -->
      <bpmndi:BPMNShape id="BPMNShape_End_ok" bpmnElement="End_ok">
        <dc:Bounds x="466" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="442" y="145" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Exception path — below normal flow, centre line y=290.
           Task_cancel x=280 (14px ahead of Task_process right=266, de facto convention). -->
      <bpmndi:BPMNShape id="BPMNShape_Task_cancel" bpmnElement="Task_cancel">
        <dc:Bounds x="280" y="250" width="100" height="80"/>
        <bpmndi:BPMNLabel><dc:Bounds x="295" y="283" width="70" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End_timeout: 50px right of Task_cancel right (380+50=430), centre y=290 -->
      <bpmndi:BPMNShape id="BPMNShape_End_timeout" bpmnElement="End_timeout">
        <dc:Bounds x="430" y="272" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="406" y="315" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Normal flow edges — all at y=120 -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="116" y="120"/>
        <di:waypoint x="166" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_normal" bpmnElement="Flow_normal">
        <di:waypoint x="266" y="120"/>
        <di:waypoint x="316" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="416" y="120"/>
        <di:waypoint x="466" y="120"/>
      </bpmndi:BPMNEdge>

      <!-- Exception flow: boundary bottom (216,178) → down to y=290, right into Task_cancel left (280,290) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_timeout" bpmnElement="Flow_timeout">
        <di:waypoint x="216" y="178"/>
        <di:waypoint x="216" y="290"/>
        <di:waypoint x="280" y="290"/>
      </bpmndi:BPMNEdge>
      <!-- Task_cancel right (380,290) → End_timeout left (430,290) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="380" y="290"/>
        <di:waypoint x="430" y="290"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
