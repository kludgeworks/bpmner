<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" expressionLanguage="http://www.w3.org/1999/XPath" id="Definitions_boundary_multi" targetNamespace="https://groknull.dev/bpmner" typeLanguage="http://www.w3.org/2001/XMLSchema">

  <bpmn:process id="Process_1" isClosed="false" isExecutable="true" name="Multi Boundary" processType="None">

    <bpmn:startEvent id="Start_1" isInterrupting="true" name="Start" parallelMultiple="false">

      <bpmn:outgoing>Flow_1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_process" implementation="##WebService" isForCompensation="false" name="Process Order" startQuantity="1">

      <bpmn:incoming>Flow_1</bpmn:incoming>

      <bpmn:outgoing>Flow_normal</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:boundaryEvent attachedToRef="Task_process" cancelActivity="true" id="Boundary_timer" name="Timeout" parallelMultiple="false">

      <bpmn:outgoing>Flow_timeout</bpmn:outgoing>

      <bpmn:timerEventDefinition id="TimerDef_1"/>

    </bpmn:boundaryEvent>

    <bpmn:boundaryEvent attachedToRef="Task_process" cancelActivity="true" id="Boundary_error" name="Error" parallelMultiple="false">

      <bpmn:outgoing>Flow_error</bpmn:outgoing>

      <bpmn:errorEventDefinition id="ErrorDef_1"/>

    </bpmn:boundaryEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_ship" implementation="##WebService" isForCompensation="false" name="Ship Order" startQuantity="1">

      <bpmn:incoming>Flow_normal</bpmn:incoming>

      <bpmn:outgoing>Flow_2</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:endEvent id="End_ok" name="Shipped">

      <bpmn:incoming>Flow_2</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_cancel" implementation="##WebService" isForCompensation="false" name="Cancel Order" startQuantity="1">

      <bpmn:incoming>Flow_timeout</bpmn:incoming>

      <bpmn:outgoing>Flow_3</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:endEvent id="End_timeout" name="Cancelled">

      <bpmn:incoming>Flow_3</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_handle" implementation="##WebService" isForCompensation="false" name="Handle Error" startQuantity="1">

      <bpmn:incoming>Flow_error</bpmn:incoming>

      <bpmn:outgoing>Flow_4</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:endEvent id="End_error" name="Failed">

      <bpmn:incoming>Flow_4</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_process"/>

    <bpmn:sequenceFlow id="Flow_normal" sourceRef="Task_process" targetRef="Task_ship"/>

    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ship" targetRef="End_ok"/>

    <bpmn:sequenceFlow id="Flow_timeout" sourceRef="Boundary_timer" targetRef="Task_cancel"/>

    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_cancel" targetRef="End_timeout"/>

    <bpmn:sequenceFlow id="Flow_error" sourceRef="Boundary_error" targetRef="Task_handle"/>

    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_handle" targetRef="End_error"/>

  </bpmn:process>
