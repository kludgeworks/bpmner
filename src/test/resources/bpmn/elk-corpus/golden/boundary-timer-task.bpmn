        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Start_1" id="BPMNShape_Start_1">
        <dc:Bounds height="36.0" width="36.0" x="12.0" y="191.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Start_1">
          <dc:Bounds height="20.0" width="90.0" x="-15.0" y="229.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_cancel" id="BPMNShape_Task_cancel">
        <dc:Bounds height="80.0" width="100.0" x="278.0" y="12.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_cancel">
          <dc:Bounds height="20.0" width="90.0" x="283.0" y="94.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_process" id="BPMNShape_Task_process">
        <dc:Bounds height="80.0" width="100.0" x="148.0" y="152.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_process">
          <dc:Bounds height="20.0" width="90.0" x="153.0" y="234.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_ship" id="BPMNShape_Task_ship">
        <dc:Bounds height="80.0" width="100.0" x="338.0" y="152.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_ship">
          <dc:Bounds height="20.0" width="90.0" x="343.0" y="234.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Boundary_timer" id="BPMNShape_Boundary_timer">
        <dc:Bounds height="36.0" width="36.0" x="180.0" y="214.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Boundary_timer">
          <dc:Bounds height="20.0" width="90.0" x="153.0" y="252.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="Flow_1" id="BPMNEdge_Flow_1">
        <di:waypoint x="48.0" y="209.0"/>
        <di:waypoint x="148.0" y="209.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_2" id="BPMNEdge_Flow_2">
        <di:waypoint x="438.0" y="192.0"/>
        <di:waypoint x="528.0" y="192.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_3" id="BPMNEdge_Flow_3">
        <di:waypoint x="378.0" y="52.0"/>
        <di:waypoint x="468.0" y="52.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_normal" id="BPMNEdge_Flow_normal">
        <di:waypoint x="248.0" y="192.0"/>
        <di:waypoint x="338.0" y="192.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_timeout" id="BPMNEdge_Flow_timeout">
        <di:waypoint x="198.0" y="250.0"/>
        <di:waypoint x="198.0" y="52.0"/>
        <di:waypoint x="278.0" y="52.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
