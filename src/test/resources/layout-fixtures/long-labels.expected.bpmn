        <di:waypoint x="432.69921875" y="65.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_3" id="BPMNEdge_Flow_3">
        <di:waypoint x="923.443359375" y="57.0"/>
        <di:waypoint x="1013.443359375" y="57.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_fail" id="BPMNEdge_Flow_fail">
        <di:waypoint x="490.056640625" y="73.0"/>
