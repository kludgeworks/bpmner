<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" expressionLanguage="http://www.w3.org/1999/XPath" id="Definitions_collab_two_pools" targetNamespace="https://groknull.dev/bpmner" typeLanguage="http://www.w3.org/2001/XMLSchema">

  <bpmn:collaboration id="Collab_two_pools" isClosed="false">

    <bpmn:participant id="Participant_buyer" name="Buyer" processRef="Process_buyer"/>

    <bpmn:participant id="Participant_seller" name="Seller" processRef="Process_seller"/>

    <bpmn:messageFlow id="MsgFlow_1" name="Purchase Order" sourceRef="Task_order" targetRef="Task_receive"/>

    <bpmn:messageFlow id="MsgFlow_2" name="Invoice" sourceRef="Task_invoice" targetRef="Task_pay"/>

  </bpmn:collaboration>

  <bpmn:process id="Process_buyer" isClosed="false" isExecutable="true" processType="None">

    <bpmn:startEvent id="Start_buyer" isInterrupting="true" name="Need Goods" parallelMultiple="false">

      <bpmn:outgoing>Flow_b1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:userTask completionQuantity="1" id="Task_order" implementation="##unspecified" isForCompensation="false" name="Place Order" startQuantity="1">

      <bpmn:incoming>Flow_b1</bpmn:incoming>

      <bpmn:outgoing>Flow_b2</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:userTask completionQuantity="1" id="Task_pay" implementation="##unspecified" isForCompensation="false" name="Pay Invoice" startQuantity="1">

      <bpmn:incoming>Flow_b2</bpmn:incoming>

      <bpmn:outgoing>Flow_b3</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:endEvent id="End_buyer" name="Done">

      <bpmn:incoming>Flow_b3</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_b1" sourceRef="Start_buyer" targetRef="Task_order"/>

    <bpmn:sequenceFlow id="Flow_b2" sourceRef="Task_order" targetRef="Task_pay"/>

    <bpmn:sequenceFlow id="Flow_b3" sourceRef="Task_pay" targetRef="End_buyer"/>

  </bpmn:process>

  <bpmn:process id="Process_seller" isClosed="false" isExecutable="true" processType="None">

    <bpmn:startEvent id="Start_seller" isInterrupting="true" name="Ready" parallelMultiple="false">

      <bpmn:outgoing>Flow_s1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_receive" implementation="##WebService" isForCompensation="false" name="Receive Order" startQuantity="1">

      <bpmn:incoming>Flow_s1</bpmn:incoming>

      <bpmn:outgoing>Flow_s2</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:serviceTask completionQuantity="1" id="Task_invoice" implementation="##WebService" isForCompensation="false" name="Send Invoice" startQuantity="1">

      <bpmn:incoming>Flow_s2</bpmn:incoming>

      <bpmn:outgoing>Flow_s3</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:endEvent id="End_seller" name="Done">

      <bpmn:incoming>Flow_s3</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_s1" sourceRef="Start_seller" targetRef="Task_receive"/>

    <bpmn:sequenceFlow id="Flow_s2" sourceRef="Task_receive" targetRef="Task_invoice"/>

    <bpmn:sequenceFlow id="Flow_s3" sourceRef="Task_invoice" targetRef="End_seller"/>

  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
