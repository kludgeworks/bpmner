        <bpmndi:BPMNLabel id="BPMNLabel_Start_seller">
          <dc:Bounds height="20.0" width="90.0" x="5.0" y="272.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_invoice" id="BPMNShape_Task_invoice">
        <dc:Bounds height="80.0" width="100.0" x="348.0" y="212.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_invoice">
          <dc:Bounds height="20.0" width="90.0" x="353.0" y="294.0"/>
