          <dc:Bounds height="120.0" width="30.0" x="-18.0" y="12.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Participant_seller" id="BPMNShape_Participant_seller" isHorizontal="true">
