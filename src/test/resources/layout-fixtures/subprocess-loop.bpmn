<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    id="Definitions_subprocess_loop"
    targetNamespace="https://groknull.dev/bpmner"
    expressionLanguage="http://www.w3.org/1999/XPath"
    typeLanguage="http://www.w3.org/2001/XMLSchema">

  <bpmn:process id="Process_1" name="Subprocess Loop" isClosed="false" isExecutable="true" processType="None">

    <bpmn:startEvent id="Start_1" name="Start" isInterrupting="true" parallelMultiple="false">
      <bpmn:outgoing>Flow_to_sub</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:subProcess id="SubProcess_1" name="Retry Loop">
      <bpmn:incoming>Flow_to_sub</bpmn:incoming>
      <bpmn:outgoing>Flow_from_sub</bpmn:outgoing>

      <bpmn:startEvent id="SubStart" name="Begin" isInterrupting="true" parallelMultiple="false">
        <bpmn:outgoing>Flow_s1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:serviceTask id="SubTask_1" name="Process Item"
          completionQuantity="1" isForCompensation="false" startQuantity="1">
        <bpmn:incoming>Flow_s1</bpmn:incoming>
        <bpmn:incoming>Flow_retry</bpmn:incoming>
        <bpmn:outgoing>Flow_check</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:exclusiveGateway id="Gw_check" name="Success?" gatewayDirection="Diverging">
        <bpmn:incoming>Flow_check</bpmn:incoming>
        <bpmn:outgoing>Flow_ok</bpmn:outgoing>
        <bpmn:outgoing>Flow_retry</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <bpmn:endEvent id="SubEnd" name="Done">
        <bpmn:incoming>Flow_ok</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_s1" sourceRef="SubStart" targetRef="SubTask_1"/>
      <bpmn:sequenceFlow id="Flow_check" sourceRef="SubTask_1" targetRef="Gw_check"/>
      <bpmn:sequenceFlow id="Flow_ok" name="yes" sourceRef="Gw_check" targetRef="SubEnd"/>
      <bpmn:sequenceFlow id="Flow_retry" name="retry" sourceRef="Gw_check" targetRef="SubTask_1"/>
    </bpmn:subProcess>

    <bpmn:endEvent id="End_1" name="End">
      <bpmn:incoming>Flow_from_sub</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_to_sub" sourceRef="Start_1" targetRef="SubProcess_1"/>
    <bpmn:sequenceFlow id="Flow_from_sub" sourceRef="SubProcess_1" targetRef="End_1"/>

  </bpmn:process>
</bpmn:definitions>
