<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  id="Definitions_collab_msg_label" targetNamespace="https://groknull.dev/bpmner">
  <bpmn:collaboration id="Collab_msg_label">
    <bpmn:participant id="Participant_customer" name="Customer" processRef="Process_customer"/>
    <bpmn:participant id="Participant_shop" name="Online Shop" processRef="Process_shop"/>
    <bpmn:messageFlow id="MsgFlow_order" name="Order Confirmation" sourceRef="Task_confirm" targetRef="Task_track"/>
    <bpmn:messageFlow id="MsgFlow_notify" name="Shipment Notification" sourceRef="Task_notify" targetRef="Task_receive_pkg"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_customer" isExecutable="true">
    <bpmn:startEvent id="Start_cust" name="Start">
      <bpmn:outgoing>Flow_c1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_track" name="Track Order">
      <bpmn:incoming>Flow_c1</bpmn:incoming>
      <bpmn:outgoing>Flow_c2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_receive_pkg" name="Receive Package">
      <bpmn:incoming>Flow_c2</bpmn:incoming>
      <bpmn:outgoing>Flow_c3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_cust" name="Done">
      <bpmn:incoming>Flow_c3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_c1" sourceRef="Start_cust" targetRef="Task_track"/>
    <bpmn:sequenceFlow id="Flow_c2" sourceRef="Task_track" targetRef="Task_receive_pkg"/>
    <bpmn:sequenceFlow id="Flow_c3" sourceRef="Task_receive_pkg" targetRef="End_cust"/>
  </bpmn:process>
  <bpmn:process id="Process_shop" isExecutable="true">
    <bpmn:startEvent id="Start_shop" name="Order Placed">
      <bpmn:outgoing>Flow_s1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_confirm" name="Confirm Order">
      <bpmn:incoming>Flow_s1</bpmn:incoming>
      <bpmn:outgoing>Flow_s2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_notify" name="Notify Shipment">
      <bpmn:incoming>Flow_s2</bpmn:incoming>
      <bpmn:outgoing>Flow_s3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_shop" name="Done">
      <bpmn:incoming>Flow_s3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_s1" sourceRef="Start_shop" targetRef="Task_confirm"/>
    <bpmn:sequenceFlow id="Flow_s2" sourceRef="Task_confirm" targetRef="Task_notify"/>
    <bpmn:sequenceFlow id="Flow_s3" sourceRef="Task_notify" targetRef="End_shop"/>
  </bpmn:process>
</bpmn:definitions>
