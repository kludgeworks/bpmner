        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_prepare" id="BPMNShape_Task_prepare">
        <dc:Bounds height="80.0" width="100.0" x="138.0" y="20.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_prepare">
          <dc:Bounds height="28.0" width="44.6953125" x="165.65234375" y="105.0"/>
