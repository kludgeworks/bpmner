        <bpmndi:BPMNLabel id="BPMNLabel_Gw_check">
          <dc:Bounds height="20.0" width="67.37109375" x="369.314453125" y="99.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Start_1" id="BPMNShape_Start_1">
        <dc:Bounds height="36.0" width="36.0" x="62.0" y="54.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Start_1">
          <dc:Bounds height="20.0" width="84.03515625" x="37.982421875" y="92.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_pack" id="BPMNShape_Task_pack">
        <dc:Bounds height="80.0" width="100.0" x="62.0" y="152.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_pack">
          <dc:Bounds height="20.0" width="60.685546875" x="81.6572265625" y="234.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_pick" id="BPMNShape_Task_pick">
        <dc:Bounds height="80.0" width="100.0" x="188.0" y="32.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_pick">
          <dc:Bounds height="20.0" width="55.341796875" x="210.3291015625" y="114.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="Flow_1" id="BPMNEdge_Flow_1">
        <di:waypoint x="98.0" y="72.0"/>
        <di:waypoint x="188.0" y="72.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_check" id="BPMNEdge_Flow_check">
