        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_pack" id="BPMNShape_Task_pack">
        <dc:Bounds height="80.0" width="100.0" x="764.083984375" y="177.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Task_pack">
          <dc:Bounds height="20.0" width="60.685546875" x="783.7412109375" y="262.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_pick" id="BPMNShape_Task_pick">
        <dc:Bounds height="80.0" width="100.0" x="256.03515625" y="32.0"/>
