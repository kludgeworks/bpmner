          <dc:Bounds height="20.0" width="78.046875" x="230.9765625" y="212.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Gw_check" id="BPMNShape_Gw_check">
