  <bpmn:collaboration id="Collab_blackbox" isClosed="false">

    <bpmn:participant id="Participant_internal" name="Internal Process" processRef="Process_internal"/>

    <bpmn:participant id="Participant_external" name="External System"/>

    <bpmn:messageFlow id="MsgFlow_out" name="Request" sourceRef="Task_send" targetRef="Participant_external"/>

    <bpmn:messageFlow id="MsgFlow_in" name="Response" sourceRef="Participant_external" targetRef="Task_receive"/>

  </bpmn:collaboration>

  <bpmn:process id="Process_internal" isClosed="false" isExecutable="true" processType="None">

    <bpmn:startEvent id="Start_1" isInterrupting="true" name="Start" parallelMultiple="false">

      <bpmn:outgoing>Flow_1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_send" implementation="##WebService" isForCompensation="false" name="Send Request" startQuantity="1">

      <bpmn:incoming>Flow_1</bpmn:incoming>

      <bpmn:outgoing>Flow_2</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:serviceTask completionQuantity="1" id="Task_receive" implementation="##WebService" isForCompensation="false" name="Receive Response" startQuantity="1">

      <bpmn:incoming>Flow_2</bpmn:incoming>

      <bpmn:outgoing>Flow_3</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:endEvent id="End_1" name="Done">

      <bpmn:incoming>Flow_3</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_send"/>

    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_send" targetRef="Task_receive"/>

    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_receive" targetRef="End_1"/>

  </bpmn:process>
