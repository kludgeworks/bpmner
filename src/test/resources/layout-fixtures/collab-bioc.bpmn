<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0"
                  id="Definitions_collab_bioc" targetNamespace="https://groknull.dev/bpmner">
  <bpmn:collaboration id="Collab_bioc">
    <bpmn:participant id="Participant_1" name="Process One" processRef="Process_1"/>
    <bpmn:participant id="Participant_2" name="Process Two" processRef="Process_2"/>
    <bpmn:messageFlow id="MsgFlow_1" sourceRef="Task_1" targetRef="Task_3"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_1" name="Send Data">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_1" name="Done">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="End_1"/>
  </bpmn:process>
  <bpmn:process id="Process_2" isExecutable="true">
    <bpmn:startEvent id="Start_2" name="Start">
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_3" name="Receive Data">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_2" name="Done">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Start_2" targetRef="Task_3"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="End_2"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_bioc">
      <bpmndi:BPMNShape id="BPMNShape_Participant_1" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="150" y="50" width="400" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start_1" bpmnElement="Start_1" bioc:stroke="#005b1d" bioc:fill="#b5efcd">
        <dc:Bounds x="182" y="152" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_1" bpmnElement="Task_1" bioc:stroke="#0d4372" bioc:fill="#bbdefb">
        <dc:Bounds x="270" y="130" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End_1" bpmnElement="End_1" bioc:stroke="#831311" bioc:fill="#ffcdd2">
        <dc:Bounds x="432" y="152" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Participant_2" bpmnElement="Participant_2" isHorizontal="true">
        <dc:Bounds x="150" y="280" width="400" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start_2" bpmnElement="Start_2">
        <dc:Bounds x="182" y="382" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_3" bpmnElement="Task_3" bioc:stroke="#6b3a0b" bioc:fill="#ffe0b2">
        <dc:Bounds x="270" y="360" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End_2" bpmnElement="End_2">
        <dc:Bounds x="432" y="382" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="218" y="170"/>
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="270" y="170"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="370" y="170"/>
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="432" y="170"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="218" y="400"/>
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="270" y="400"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="370" y="400"/>
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="432" y="400"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_MsgFlow_1" bpmnElement="MsgFlow_1">
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="320" y="210"/>
        <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="320" y="360"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
