      <bpmn:outgoing>Flow_1</bpmn:outgoing>
          
    </bpmn:startEvent>
        
    <bpmn:serviceTask completionQuantity="1" id="Task_process" implementation="##WebService" isForCompensation="false" name="Process Payment" startQuantity="1">
            
      <bpmn:incoming>Flow_1</bpmn:incoming>
            
      <bpmn:outgoing>Flow_normal</bpmn:outgoing>
          
    </bpmn:serviceTask>
        
    <bpmn:boundaryEvent attachedToRef="Task_process" cancelActivity="true" id="Boundary_error" name="Payment Error" parallelMultiple="false">
            
      <bpmn:outgoing>Flow_error</bpmn:outgoing>
            
      <bpmn:errorEventDefinition id="ErrorDef_1"/>
          
    </bpmn:boundaryEvent>
        
    <bpmn:userTask completionQuantity="1" id="Task_confirm" implementation="##unspecified" isForCompensation="false" name="Confirm" startQuantity="1">
            
      <bpmn:incoming>Flow_normal</bpmn:incoming>
            
      <bpmn:incoming>Flow_rejoin</bpmn:incoming>
            
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
          
    </bpmn:userTask>
        
    <bpmn:endEvent id="End_1" name="End">
            
      <bpmn:incoming>Flow_2</bpmn:incoming>
          
    </bpmn:endEvent>
        
    <bpmn:serviceTask completionQuantity="1" id="Task_handle" implementation="##WebService" isForCompensation="false" name="Handle Error" startQuantity="1">
            
      <bpmn:incoming>Flow_error</bpmn:incoming>
            
      <bpmn:outgoing>Flow_rejoin</bpmn:outgoing>
          
    </bpmn:serviceTask>
        
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_process"/>
        
    <bpmn:sequenceFlow id="Flow_normal" sourceRef="Task_process" targetRef="Task_confirm"/>
        
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_confirm" targetRef="End_1"/>
        
    <bpmn:sequenceFlow id="Flow_error" sourceRef="Boundary_error" targetRef="Task_handle"/>
        
    <bpmn:sequenceFlow id="Flow_rejoin" sourceRef="Task_handle" targetRef="Task_confirm"/>
      
  </bpmn:process>
