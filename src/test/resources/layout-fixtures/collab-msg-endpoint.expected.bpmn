  <bpmn:process id="Process_A" isClosed="false" isExecutable="true" processType="None">

    <bpmn:startEvent id="Start_A" isInterrupting="true" name="Start" parallelMultiple="false">

      <bpmn:outgoing>Flow_A1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:serviceTask completionQuantity="1" id="Task_A1" implementation="##WebService" isForCompensation="false" name="Call Service B" startQuantity="1">

      <bpmn:incoming>Flow_A1</bpmn:incoming>

      <bpmn:outgoing>Flow_A2</bpmn:outgoing>

    </bpmn:serviceTask>

    <bpmn:userTask completionQuantity="1" id="Task_A2" implementation="##unspecified" isForCompensation="false" name="Handle Response" startQuantity="1">

      <bpmn:incoming>Flow_A2</bpmn:incoming>

      <bpmn:outgoing>Flow_A3</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:endEvent id="End_A" name="Done">

      <bpmn:incoming>Flow_A3</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="Start_A" targetRef="Task_A1"/>

    <bpmn:sequenceFlow id="Flow_A2" sourceRef="Task_A1" targetRef="Task_A2"/>

    <bpmn:sequenceFlow id="Flow_A3" sourceRef="Task_A2" targetRef="End_A"/>

