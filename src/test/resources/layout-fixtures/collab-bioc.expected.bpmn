    <bpmn:serviceTask completionQuantity="1" id="Task_3" implementation="##WebService" isForCompensation="false" name="Receive Data" startQuantity="1">

      <bpmn:incoming>Flow_3</bpmn:incoming>

      <bpmn:outgoing>Flow_4</bpmn:outgoing>

