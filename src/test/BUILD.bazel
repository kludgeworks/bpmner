load("@contrib_rules_jvm//java:defs.bzl", "java_junit5_test")
load("@rules_java//java:defs.bzl", "java_binary")
load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_library")
load("@rules_kotlin//kotlin:lint.bzl", "ktlint_test")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//tools/kotlin:spring.bzl", "spring_allopen_plugins")

package(default_visibility = ["//visibility:private"])

sh_test(
    name = "bpmnerAppJarStructureTest",
    srcs = ["jar_structure_test.sh"],
    args = ["$(location //src:bpmner_app.jar)"],
    data = ["//src:bpmner_app.jar"],
    visibility = ["//visibility:public"],
)

sh_test(
    name = "bpmnerAppRunfilesDataTest",
    srcs = ["runfiles_data_test.sh"],
    args = ["$(location //src:bpmner_app)"],
    data = ["//src:bpmner_app"],
    visibility = ["//visibility:public"],
)

kt_jvm_library(
    name = "bpmner_tests_lib",
    srcs = glob(["kotlin/**/*.kt"]),
    associates = ["//src:bpmner_core"],
    plugins = spring_allopen_plugins(),
    resources = glob(["resources/**"]),
    deps = [
        "@maven//:com_embabel_agent_embabel_agent_test",
        "@maven//:com_tngtech_archunit_archunit",
        "@maven//:org_camunda_bpm_model_camunda_bpmn_model",
        "@maven//:org_graalvm_polyglot_js",
        "@maven//:org_graalvm_polyglot_polyglot",
        "@maven//:org_jetbrains_kotlin_kotlin_reflect",
        "@maven//:org_jetbrains_kotlin_kotlin_stdlib",
        "@maven//:org_jetbrains_kotlin_kotlin_test_junit5",
        "@maven//:org_jmolecules_integrations_jmolecules_archunit",
        "@maven//:org_springframework_boot_spring_boot_starter_test",
        "@maven//:org_springframework_modulith_spring_modulith_starter_test",
        "@rules_java//java/runfiles",
    ],
)

java_binary(
    name = "update_prompt_baselines",
    main_class = "dev.groknull.bpmner.prompt.UpdatePromptBaselinesKt",
    visibility = ["//visibility:public"],
    runtime_deps = [":bpmner_tests_lib"],
)

filegroup(
    name = "analysis_srcs",
    srcs = glob(["kotlin/**/*.kt"]),
    visibility = ["//visibility:public"],
)

TIMEOUT_OVERRIDES = {
    "ActivityLabelCapitalizationTest": "moderate",
    "BpmnConfigBindingTest": "moderate",
    "BpmnNlpConcurrencyTest": "long",
    "BpmnSubsetTest": "moderate",
    "BpmnerModuleBoundariesTest": "moderate",
    "BpmnerModulithTest": "moderate",
    "BusinessMeaningfulLabelTest": "moderate",
    "EventStatePatternTest": "moderate",
    "NoDuplicateDiagramsTest": "moderate",
    "PklRuleCatalogTest": "moderate",
    "RepairStartupValidationTest": "moderate",
    "UncommonAbbreviationsTest": "moderate",
    "VerbObjectNameTest": "moderate",
}

SHARD_COUNTS = {
    "BpmnContractFidelityCheckerTest": 4,
    "BpmnContractValidatorTest": 2,
    "BpmnDefinitionToXmlConverterTest": 2,
    "BpmnDefinitionValidatorTest": 3,
    "BpmnOwnershipTest": 2,
    "BpmnPatchApplierTest": 4,
    "BpmnReadinessPostCheckerTest": 2,
    "BpmnXmlToDefinitionConverterTest": 2,
    "DeterministicPrimitivesTest": 3,
    "EventDefinitionRuleTest": 2,
    "FlatContractMapperTest": 2,
    "PklRuleCatalogTest": 3,
    "TopologyHandlersTest": 3,
}

EXTRA_TAGS = {
    "ActiveLiveLlmProfileConditionTest": ["spring-context"],
    "BpmnAgentFlowSystemTest": ["spring-context"],
    "BpmnGuardrailSystemTest": ["spring-context"],
    "BpmnNlpConcurrencyTest": ["concurrency"],
    "BpmnWebControllerTest": ["spring-context"],
    "BpmnerApplicationTests": ["spring-context"],
}

TEST_FILES = glob(["kotlin/**/*Test.kt"])

[java_junit5_test(
    name = f.split("/")[-1].replace(".kt", ""),
    timeout = TIMEOUT_OVERRIDES.get(
        f.split("/")[-1].replace(".kt", ""),
        "eternal" if "SmokeTest" in f else "long" if "GuardrailSystemTest" in f else "moderate" if "AgentFlowSystemTest" in f or "ModuleTest" in f or "ArchitectureTest" in f or "IntegrationTest" in f else "short",
    ),
    data = ["//samples:prose_samples"] if "FullPipelineSmokeTest" in f else [],
    env_inherit = [
        "ANTHROPIC_API_KEY",
        "GEMINI_API_KEY",
        "GITHUB_TOKEN",
        "OPENAI_API_KEY",
        "SPRING_PROFILES_ACTIVE",
    ] if "SmokeTest" in f else [],
    shard_count = SHARD_COUNTS.get(
        f.split("/")[-1].replace(".kt", ""),
        1,
    ),
    tags = (
        [
            "live-llm",
            "manual",
            "no-remote",
        ] if "FullPipelineSmokeTest" in f else [
            "live-llm",
            "no-remote",
        ] if "SmokeTest" in f and "ContractVocabulary" not in f else ["integration"] if "IntegrationTest" in f else []
    ) + EXTRA_TAGS.get(
        f.split("/")[-1].replace(".kt", ""),
        [],
    ),
    test_class = f.replace("kotlin/", "").replace(".kt", "").replace("/", "."),
    visibility = ["//visibility:public"],
    runtime_deps = [
        ":bpmner_tests_lib",
        "@maven//:org_junit_jupiter_junit_jupiter_engine",
        "@maven//:org_junit_platform_junit_platform_launcher",
        "@maven//:org_junit_platform_junit_platform_reporting",
    ],
) for f in TEST_FILES]

ktlint_test(
    name = "ktlint_check",
    srcs = glob(["kotlin/**/*.kt"]),
    config = "//:ktlint_config",
    visibility = ["//visibility:public"],
)
